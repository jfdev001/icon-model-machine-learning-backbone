#--------------------------------------------------------------------------------------------------
#
# Example config for a standard AMIP experiment with an atmosphere
# using NWP physics with JSBACH/VDIFF land surface scheme and turbulence.
#

ENVIRONMENT  = levante
ACCOUNT      =

EXP_TYPE     = amip-nwp-R2B4

INITIAL_DATE = 1979-01-01
FINAL_DATE   = 1981-01-01
INTERVAL     = P1Y

[jobs]
  [[run]]
    use_mpmd     = false
    use_hostfile = false
    use_cpu_mask = false
    threads_per_task = 1
    nodes = 20
    time_limit = 00:30:00

# *** Examples of common modifications (add above the jobs section if required)
# ------------------------------------------------------------------------
# # Add output variables
# [namelists]
#   [[NAMELIST_atm]]
#     [[[output_nml lnd_basic]]]
#       ml_varlist += hydro_weq_balance_err_count_box
#
# ------------------------------------------------------------------------
# # Change namelist switches
# [namelists]
#   [[NAMELIST_lnd]]
#     [[[jsb_hydro_nml]]]
#       enforce_water_budget = logging
#
# ------------------------------------------------------------------------
# # Run with natural land cover change (nlcc; former dynveg)
# [namelists]
#   [[NAMELIST_lnd]]
#     [[[jsb_nlcc_nml]]]
#       active = true
#
# # Note: Set land option init_nlcc to initialize nlcc in case
# #       - this is an initialized experiment, or
# #       - the parent experiment was not run with dynamic vegetation
# EXP_OPTIONS = land/init_nlcc
#
# ------------------------------------------------------------------------
# # Run without HD-Model
# LAND_WITH_HD = false
#
# ------------------------------------------------------------------------
# # Generate daily forcing for jsbalone simulations
# EXP_OPTIONS = land/generate_forcing
