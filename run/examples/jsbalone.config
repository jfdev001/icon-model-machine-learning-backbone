#--------------------------------------------------------------------------------------------------
#
# Example config for a standard JSBACH standalone experiment
#

ENVIRONMENT  = levante
ACCOUNT      =

EXP_TYPE     = jsbalone-R2B4

INITIAL_DATE = 1979-01-01
FINAL_DATE   = 2019-01-01
INTERVAL     = P1Y

[jobs]
  [[run]]
    use_mpmd = false
    use_hostfile = false

# *** Examples of common modifications (add above the jobs section if required)
# ------------------------------------------------------------------------
# # Add output variables and change namelist switches
# [namelists]
#   [[NAMELIST_lnd]]
#     [[[jsb_hydro_nml]]]
#       enforce_water_budget = logging
#     [[[output_nml lnd_basic]]]
#       ml_varlist += hydro_weq_balance_err_count_box
#
# ------------------------------------------------------------------------
# # Run without HD-Model
# LAND_WITH_HD = false
#
# ------------------------------------------------------------------------
# # Run JSBACH lite usecase (no PFTs and no carbon processes)
# LAND_USECASE     = jsbach_lite
# LAND_WITH_CARBON = false    # Carbon needs to be disabled with jsbach_lite
#
# ------------------------------------------------------------------------
# # Choose amip forcing for JSB_Forcing
# EXP_OPTIONS        = land/with_amip_forcing  # Use model forcing
# FORCING_LABEL      = amip-nwp_jsbalone_ml    # Forcing file name without year
# FORCING_INPUT_ROOT = /work/XXXXXX            # Forcing base directory (replace with your path)
# FORCING_SUBDIR     = amip-nwp/outdata        # Forcing sub directory (replace with your path)
