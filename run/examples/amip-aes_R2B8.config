#
# Example config for a standard AMIP experiment with standalone atmosphere
# using AES physics with JSBACH land surface scheme and TMX turbulence
# (nextGEMS namelist)
# This experiment corresponds to run/exp.aes_amip.run for the R02B08 grid.
#

EXP_TYPE = amip-aes-R2B8
EXP_OPTIONS = suppress_default_output
ENVIRONMENT = levante
ACCOUNT = eval(feedback.die("please set ACCOUNT in your experiment config"))

# For testing we use only short runtime
INITIAL_DATE = 1979-01-01T00:00:00
FINAL_DATE = 1979-01-01T03:00:00 # Performance ~0.99sim.h/node.hour (icon-mpim:master, 59e79b65, 2025-02-17)
INTERVAL = PT3H # Restart interval

[jobs]
  [[run]]
    .trigger = run # disable post-processing for now
    use_mpmd = false
    use_hostfile = false
    use_cpu_mask = false
    nodes = 32
    threads_per_task = 4
    time_limit = 00:10:00

[MPI]
  command = "srun -l --kill-on-bad-exit=1 --cpu-bind=quiet,cores --distribution=plane=32 --propagate=STACK,CORE"
