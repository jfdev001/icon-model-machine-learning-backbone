#
#  bubble on a torus
#

EXP_TYPE = torus
ENVIRONMENT = levante
ACCOUNT = mh0287

ATMO_LEVELS = 70
ATMO_TIME_STEP = PT30S
ATMO_RADIATION_TIME_STEP = PT2M

INITIAL_DATE = 2008-08-01T00:00:00Z
FINAL_DATE = 2008-08-01T02:00:00Z
INTERVAL = P1D

OUTPUT_INTERVAL = $ATMO_TIME_STEP

[namelists]
  [[NAMELIST_atm]]
    [[[aes_phy_nml]]]
      aes_phy_config(1)%dt_mig = $ATMO_TIME_STEP
    [[[nh_testcase_nml]]]
      nh_test_name = 'aes_bubble'
      ape_sst_case = 'sst_const'
      ape_sst_val = 30.0
    [[[output_nml atm_2d]]]
      ml_varlist = ps, psl, ts, clt, prw, cllvi, clivi, qrvi, qsvi, qgvi, hfls, hfss, evspsbl, prlr, prls, cptgzvi, pr_rain, pr_snow, pr_grpl, pr_ice
      operation =
      output_grid = true
    [[[output_nml atm_3d]]]
      ml_varlist = ps, pfull, zg, rho, ta, theta_v, ua, va, wa, hus, clw, cli, qr, qs, qg, cptgz
      operation =
      output_grid = true

[jobs]
  [[run]]
    nodes = 1
    threads_per_task = 4
    time_limit = 00:05:00
    use_hostfile = false
    use_mpmd = false
