#
# Torus
#
# The is a default type that initializes the model
# to run with uniform boundary conditions on a torus.
#
# It serves as the root type for the bubble and rce
# experiments in examples.
#

VERSION_ = $$Id: run/mkexp/types/torus.config 5 2024-08-02 13:01:10Z m221078 $$

ATMO_GRID_TYPE =
ATMO_GRID_ID = Torus_Triangles_20x4_5000m

OCEAN_GRID_TYPE =
OCEAN_BLOCK_SIZE =
OCEAN_TIME_STEP =
OCEAN_GRID_ID =

COUPLER_TIME_STEP =

WITH_LAND = false
WITH_OCEAN = false

LAND_USECASE = jsbach_lite
LAND_WITH_LAKES = false

CALENDAR = 360 day year

[namelists]
  [[NAMELIST_atm]]
    .remove += dbg_index_nml, extpar_nml, initicon_nml, output_nml atm_vgrid, output_nml atm_dbg, output_nml atm_mon, output_nml lnd_mon
    [[[aes_cov_nml]]]
      aes_cov_config(1)%cqx = 1.e-6
    [[[aes_phy_nml]]]
      aes_phy_config(1)%iqneg_d2p = 2
      aes_phy_config(1)%iqneg_p2d = 2
      aes_phy_config(1)%lice =
      aes_phy_config(1)%zmaxcloudy = 22500.
    [[[aes_rad_nml]]]
      aes_rad_config(1)%cecc = 0.0
      aes_rad_config(1)%cobld = 0.0
      aes_rad_config(1)%irad_o2 = 0
      aes_rad_config(1)%irad_o3 = 0
      aes_rad_config(1)%isolrad = 5
      aes_rad_config(1)%l_orbvsop87 = false
      aes_rad_config(1)%l_sph_symm_irr = true
      aes_rad_config(1)%ldiur = false
      # Remove from DEFAULT settings
      aes_rad_config(1)%lyr_perp =
      aes_rad_config(1)%vmr_ch4 =
      aes_rad_config(1)%vmr_co2 =
      aes_rad_config(1)%vmr_n2o =
      aes_rad_config(1)%yr_perp =
    [[[aes_vdf_nml]]]
      aes_vdf_config(1)%pr0 = 0.7
      aes_vdf_config(1)%turb = 2
      aes_vdf_config(1)%use_tmx = true
    [[[dynamics_nml]]]
      lcoriolis = false
      lmoist_thdyn = true
    [[[grid_nml]]]
      grid_angular_velocity = 0.
    [[[interpol_nml]]]
      rbf_vec_scale_c = 0.45
      rbf_vec_scale_e = 0.45
      rbf_vec_scale_v = 0.45
    [[[io_nml]]]
      lnetcdf_flt64_output = true
      write_initial_state =
    [[[nonhydrostatic_nml]]]
      damp_height = 22500.
      divdamp_fac = 0.002
      ndyn_substeps = 5
    [[[output_nml atm_cgrid]]]
      filename_format = <output_filename>_<levtype_l>
      include_last =
      ml_varlist = clon, clat, areacella, zghalf, zg
      output_end = $INITIAL_DATE
      output_grid = true
    [[[parallel_nml]]]
      io_process_stride = 6
      nproma = 32
      nproma_sub = 32
      num_io_procs = 2
      pio_type =
    [[[run_nml]]]
      iforcing = 2
      ltestcase = true
      msg_level = 12
      output = nml
      profiling_output = 1
      restart_filename = ${EXP_ID}_restart_atm_<rsttime>.nc
    [[[sleve_nml]]]
      flat_height = 30000.
      htop_thcknlimit = 30000.
      max_lay_thckn = 400.
      min_lay_thckn = 20.
      stretch_fac = 0.7
      top_height = 30000.
    [[[transport_nml]]]
      ihadv_tracer = 52, 2, 2, 2, 2, 2
      itype_hlimit = 3, 4, 4, 4, 4, 4
      ivadv_tracer = 3, 3, 3, 3, 3, 3
      tracer_names = hus, clw, cli, qr, qs, qg
  [[icon_master.namelist]]
    [[[master_nml]]]
      lrestart = false
    [[[master_time_control_nml]]]
      experimentstartdate = $INITIAL_DATE
  [[NAMELIST_lnd]]
    [[[jsb_model_nml]]]
      use_tmx = true
      use_glacier = false
    [[[jsb_carbon_nml]]]
      .hide = true
    [[[jsb_disturb_nml]]]
      .hide = true
    [[[jsb_fuel_nml]]]
      .hide = true
    [[[jsb_hd_nml]]]
      .hide = true
    [[[jsb_hydro_nml]]]
      snow_depth_max =
    [[[jsb_sse_nml]]]
      l_supercool = false

[files]
  [[atmosphere]]
    [[[restart_data]]]
      .hide = true
    [[[restart]]]
      .hide = true

    [[[model]]]
      [[[[data]]]]
        .sub_dir = data
        rrtmgp-cloud-optics-coeffs-lw.nc = ECHAM6_CldOptProps_rrtmgp_lw.nc
        rrtmgp-cloud-optics-coeffs-sw.nc = ECHAM6_CldOptProps_rrtmgp_sw.nc
        dmin_wetgrowth_lookup.nc = .
        coefficients_lw.nc = rrtmgp-gas-lw-g128.nc
        coefficients_sw.nc = rrtmgp-gas-sw-g112.nc
    [[[mapped]]]
      icon_grid_G.nc = $ATMO_GRID_ID.nc
      [[[[ozone]]]]
        .base_dir = $${atmosphere_dir}/Torus_Triangles_20x22_5000m
        .sub_dir = r0006
        bc_ozone.nc = rcemip_analytical_o3_20x22_5000m_echam_plev.nc

  [[land]]
    [[[mapped]]]
      .sub_dir = $ATMO_GRID_ID/land/r0001
    [[[hydro]]]
      .hide = true

[jobs]
  .remove += clean, intake, mon, mon_index, post, run
  [[run]]
    .trigger =
