VERSION_ = $$Id: run/mkexp/environments/levante_gpu.config 1 20245-01-09 k202123 $$

WORK_ROOT = "eval('/scratch/'+'$USER'[0]+'/$USER')"
DATA_ROOT = /work/$PROJECT_SUBDIR/$USER

# Distribution of the IO tasks among the CPUs of the GPU nodes
#  it calculate num_io_procs based on choosen number of nodes and num_io_tasks
IO_DISTRIBUTION_OVER_GPUS = true
[namelists]
  [[NAMELIST_atm]]
    [[[parallel_nml]]]
      num_io_procs = raw($${num_io_procs})

[jobs]

  ldd = ldd
  batch_command = sbatch
  progress_command = sh -c 'scontrol update JobId=$$SLURM_JOB_ID Comment="$$*"' scomment
  ksh = /bin/bash

  # Environment variables for job information
  name_environ = SLURM_JOB_NAME
  id_environ = SLURM_JOBID
  [[run]]
    use_gpus = true
    use_cpu_mask = false
    use_hostfile = true
    use_mpmd = false       # no --multi-prog icon_mpmd.conf
    partition = gpu
    nodes = 1
    gpus_per_node = 4
    threads_per_task = 1   # =OMP_NUM_THREADS
    stack_size = unlimited
    [[[env]]]
      # OpenMP
      OMP_DYNAMIC = false
      OMP_SCHEDULE = dynamic, 1
      OMP_STACKSIZE = 200M
      # Unified Communication X
      UCX_RNDV_THRESH = 16384
      # GNU C Library
      MALLOC_TRIM_THRESHOLD_ = -1


  [[mon]]
    partition = shared

  [[clean]]
    partition = compute
    tasks = 128
    time_limit = 30

  [[intake]]
    python3 = /usr/bin/env python3

[MPI]
  command = "srun -l --kill-on-bad-exit=1 --export=ALL --gpus-per-node=4"
