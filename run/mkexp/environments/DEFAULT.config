VERSION_ = $$Id: run/mkexp/environments/DEFAULT.config 4 2025-03-04 15:02:22Z m221078 $$

[jobs]

  ldd = ldd
  progress_command = echo progress indicator:

  # Environment variables for job information
  name_environ = 0
  id_environ = $$

  log_file = $EXP_ID.run.$$(printf %08d $$$id_environ).log

[MPI]

  command = mpiexec
