VERSION_ = $$Id: amip-R2B4.config 1 2021-11-10 17:43 m212005 $$

SCENARIO = ssp245  # used to prescribe CO2 scenario
                   # set to '' to use a constant value defined in the CO2 forcing namelist

# Land setup (only differences to DEFAULT.config)
# Currently, the land uses ATMO variables for time step and grid information
LAND_REFERENCE_YEAR = 1979
ATMO_BLOCK_SIZE     = 128
ATMO_TIME_STEP      = PT15M        # 96 time steps per day
ATMO_GRID_ID        = 0049
ATMO_GRID_TYPE      = R02B04

# Switch off all other model components
WITH_ATMO = false
WITH_OCEAN = false
WITH_OBGC = false

# Variables that needs to be unset to avoid issues with DEFAULT.config
ATMO_RADIATION_TIME_STEP = $ATMO_TIME_STEP
OCEAN_GRID_ID =
OCEAN_GRID_TYPE =
OCEAN_BLOCK_SIZE =
OCEAN_TIME_STEP =
COUPLER_TIME_STEP =

# Time control
INITIAL_DATE    = 1979-01-01
FINAL_DATE      = 2019-01-01
INTERVAL        = P1Y
OUTPUT_INTERVAL = P1M

# Atmospheric forcing information
FORCING_LABEL         = "climate_gswp3-w5e5_daily"
FORCING_INPUT_ROOT    = /pool/data/JSBACH/jsbalone_forcing/${ATMO_GRID_TYPE}/${ATMO_GRID_ID}
FORCING_SUBDIR        = GSWP3-W5E5/data
CYCLE_PERIOD          = 28
INITIAL_CLIMYEAR      = 1901
FINAL_CLIMYEAR        = 2019

[namelists]
  [[icon_master.namelist]]
    [[[master_time_control_nml]]]
      experimentstartdate = $INITIAL_DATE
    [[[jsb_control_nml]]]
      is_standalone    = true
      l_force_from_obs = true
    [[[time_nml]]]
      is_relative_time = false

  [[NAMELIST_lnd]]
    [[[parallel_nml]]]
      nproma = $ATMO_BLOCK_SIZE
    [[[grid_nml]]]
      dynamics_grid_filename = icon_grid_G.nc
    [[[run_nml]]]
      num_lev = 1
      modeltimestep = $ATMO_TIME_STEP
      ltestcase = false # run testcase
      ldynamics = false # dynamics
      ltransport = false # transport
      ntracer = 3
      iforcing = 2 # 0: none, 1: HS, 2: ECHAM, 3: NWP
      output = nml
      msg_level = 0 # level of details report during integration
      restart_filename = ${EXP_ID}_restart_jsbalone_<rsttime>.nc
      activate_sync_timers = false
      ltimer = true
      timers_level = 10
    [[[jsb_model_nml]]]
      fract_filename  = "bc_land_frac.nc"
      enforce_water_budget = error # water balance errors levels: error, logging, ignore
    [[[jsb_hydro_nml]]]
      l_organic = True
    [[[jsb_hd_nml]]]
      diag_water_budget = false
    [[[io_nml]]]
      restart_file_type = 5
      restart_write_mode = "sync"  # Default: " " =Fallback mode. If num_restart_proc == 0 (parallel_nml),
                                   # then this behaves like "sync", otherwise like "async".
                                   # If async is choosen, the num_restart_procs must be bigger than 0!
                                   # "joint procs multifile" not necessary/useful in default r2b4 setup.
      .end =
    [[[jsb_forcing_nml]]]
      # General forcing settings
      forcing_steps_per_day          = 1     # The number of time steps included by the used forcing file(s); 1 for daily records
      forcing_height_wind            = 10    # Height of wind measurements (set to -1 for atm model forcing)
      forcing_height_humidity        = 2     # Height of humidity and temperature measurements (set to -1 for atm model forcing)
      forcing_set_ocean_to_constants = false # false for global forcing, true if no values exist over ocean
      #--- temperature forcing ----
      forcing_temp_file_prefix       = "climate_"
      forcing_temp_frequ             = "DAILY"  # Forcing frequency (DAILY/TIMESTEP/CONST)
      forcing_temp_unit              = "degC"
      #--- precipitation forcing ----
      forcing_precip_file_prefix     = "climate_"
      forcing_precip_frequ           = "DAILY"  # Forcing frequency (DAILY/TIMESTEP/CONST)
      forcing_precip_in_mm_per_day   = false
      forcing_precip_unit            = "kg m-2 s-1"
      #--- atmospheric humidity forcing
      forcing_qair_file_prefix       = "climate_"
      forcing_qair_type              = "QAIR"   # (QAIR/RH/NONE)
      forcing_qair_frequ             = "DAILY"  # Forcing frequency (DAILY/TIMESTEP/CONST)
      forcing_qair_unit              = "kg kg-1"
      #--- longwave radiative forcing ---
      forcing_lw_file_prefix         = "climate_"
      forcing_lw_frequ               = "DAILY"  # Forcing frequency (MONTHLY/DAILY/CONST)
      forcing_lw_unit                = "W m-2"
      #--- shortwave radiative forcing ---
      forcing_sw_file_prefix         = "climate_"
      forcing_sw_frequ               = "DAILY"  # Forcing frequency (DAILY/TIMESTEP/CONST)
      forcing_sw_unit                = "W m-2"
      # --- wind speed forcing ---
      forcing_wind_file_prefix       = "climate_"
      forcing_wind_frequ             = "DAILY"  # Forcing frequency (DAILY/TIMESTEP/CONST)
      forcing_wind_unit              = "m s-1"
      # --- CO2 forcing ---
      forcing_co2_file_prefix        = "bc_greenhouse_gases.nc"
      forcing_co2_frequ              = eval('CONST' if '$SCENARIO' == '' else 'GHG_SCENARIO')  # Forcing frequency (DAILY/TIMESTEP/CONST/GHG_SCENARIO)
                                                                                               # Should be GHG_SCENARIO if any SCENARIO is prescribed
      forcing_co2_const_co2          = 367      # default for 1999
      forcing_co2_unit               = "ppmv"

    # jsbach output for running jsbalone experiments
    # Default settings for 'output_nml *'
    [[[output_nml]]]
      output_filename = ${EXP_ID}_%{id}
      filename_format = <output_filename>_<levtype_l>_<datetime2>
      filetype = 5 # output format: 2=GRIB2, 4=NETCDFv2, 5=NETCDFv4
      mode = 1 # 1: forecast mode (relative t-axis), 2: climate mode (absolute t-axis)
      output_start = $INITIAL_DATE
      output_end = $FINAL_DATE
      output_interval = $OUTPUT_INTERVAL
      file_interval = $FILE_INTERVAL
      include_last = false
    [[[output_nml lnd_basic]]]
      .hide = eval($land_output_level < 1)
      operation = mean
      output_grid = true
      ml_varlist = group:jsb_all_basic
    [[[output_nml lnd_medium]]]
      .hide = eval($land_output_level < 2)
      operation = mean
      output_grid = true
      ml_varlist = group:jsb_all_medium
    [[[output_nml lnd_full]]]
      .hide = eval($land_output_level < 3)
      operation = mean
      output_grid = true
      ml_varlist = group:jsb_all_full
    [[[output_nml lnd_mon]]]
      filename_format = <output_filename>_<datetime2>
      operation = mean # mean over output interval
      output_grid = false
      remap = 0
      ml_varlist = group:jsb_mon

[files]
  [[land]]
    .sub_dir = $ATMO_GRID_ID
    icon_grid_G.nc = icon_grid_${ATMO_GRID_ID}_${ATMO_GRID_TYPE}_G.nc
    [[[mapped]]]
      .sub_dir = land/r0101
    [[[hydro]]]
      .sub_dir = land/r0101
      bc_land_hd.nc = hdpara_r2b4_${ATMO_GRID_ID}_sc_hfrac_s_v1.nc
    [[[independent]]]
      .base_dir = $INPUT_ROOT/ICON/grids/public/mpim/independent
      bc_greenhouse_gases.nc = greenhouse_gases/greenhouse_$SCENARIO.nc
    [[[forcing]]]
      .offsets = -1, 0
      .base_dir = $FORCING_INPUT_ROOT/$FORCING_SUBDIR
      .set climyear = $( get_climyear %year $INITIAL_CLIMYEAR $FINAL_CLIMYEAR $CYCLE_PERIOD )
      .method = "cdo_set_date %year $$climyear"
      climate_%year.nc = ${FORCING_LABEL}_$$climyear*.nc
#
# Initialize land only from standard climatology
#
[jobs]
  [[run]]
    .trigger = run, post
    nodes = 1
    threads_per_task = 1
    share_nodes = false
    use_hostfile = false
    use_mpmd = false
    time_limit = 02:00:00

  [[run_start]]
    .lrestart = false

    [[[namelists]]]
      [[[[icon_master.namelist]]]]
        [[[[[master_nml]]]]]
          lrestart = ${.lrestart}
          read_restart_namelists = false
        [[[[[jsb_control_nml]]]]]
          restart_jsbach = ${.lrestart}
      [[[[NAMELIST_lnd]]]]
        [[[[[jsb_hd_nml]]]]]
          read_initial_reservoirs = true

    [[[files]]]
      [[[[land]]]]
        [[[[[restart]]]]]
          .base_dir = $WORK_DIR
          restart_jsbach_DOM01.nc =
        [[[[[hydro]]]]]
          ic_land_hd.nc = hdstart_r2b4_${ATMO_GRID_ID}_sc_hfrac_s_v1.nc

  [[post]]
    tasks = 8
    time_limit = 00:10:00
  [[mon]]
    tasks = 4
    time_limit = 00:05:00

[MPI]
  command = "srun -l --hint=nomultithread --cpu-bind=v --distribution=block:cyclic:block"
