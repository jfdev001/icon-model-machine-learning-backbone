# ------------------------------------------

VERSION_ = $$Id: amip-R2B4.config 1 2021-11-10 17:43 m212005 $$

# Atmosphere setup

ATMO_GRID_ID             = 0049
ATMO_GRID_TYPE           = R02B04
ATMO_LEVELS              = 90
ATMO_BLOCK_SIZE          = 32
ATMO_TIME_STEP           = PT720S  # 12min time step
ATMO_DYNAMICS_SUBSTEPS   = 10
ATMO_TIME_STEP_SEC       = period2sec($ATMO_TIME_STEP)
ATMO_RADIATION_TIME_STEP = eval($ATMO_TIME_STEP_SEC * 3)

# Land setup

LAND_REFERENCE_YEAR = 1979

# Switch off ocean
WITH_OCEAN = false
WITH_OBGC  = false

# Variables that needs to be unset to avoid issues with DEFAULT.config
OCEAN_GRID_TYPE =
OCEAN_TIME_STEP =
OCEAN_BLOCK_SIZE =
OCEAN_GRID_ID =
COUPLER_TIME_STEP =

# Time control

INITIAL_DATE    = 1979-01-01
FINAL_DATE      = 2016-01-01
INTERVAL        = P1Y
OUTPUT_INTERVAL = P1M

[namelists]
  [[icon_master.namelist]]
    [[[master_time_control_nml]]]
      experimentstartdate = $INITIAL_DATE
  [[NAMELIST_atm]]
    [[[run_nml]]]
      iforcing = 3 # 0: none, 1: HS, 2: ECHAM, 3: NWP
      ntracer  = 5
    [[[io_nml]]]
      itype_pres_msl  = 4           # 5: new DWD method; 4: IFS method with bug fix for self-consistency between SLP and geopotential
      itype_rh        = 1           # RH w.r.t. water
      precip_interval = "P1M"
      maxt_interval   = "P1M"
      lnetcdf_flt64_output = false  # T: 64 bit output in all files
    [[[sleve_nml]]]
      min_lay_thckn   = 20.         # [m]  lowest level thickness (between half-levels)
      max_lay_thckn   = 400.        # [m]  maximum layer thickness below htop_thcknlimit
      htop_thcknlimit = 14000.      # [m]
      top_height      = 75000.      # [m]
      stretch_fac     = 0.9
      decay_scale_1   = 4000.
      decay_scale_2   = 2500.
      decay_exp       = 1.2
      flat_height     = 16000.
    [[[nonhydrostatic_nml]]]
      iadv_rhotheta       = 2
      ivctype             = 2
      itime_scheme        = 4
      exner_expol         = 0.333
      vwind_offctr        = 0.3
      damp_height         = 44000.  # [m]
      divdamp_type        = 3
      rayleigh_coeff      = 0.1
      divdamp_order       = 4       # 24 is not allowed for checkpoint_interval < 2.5h
      igradp_method       = 3
      l_zdiffu_t          = true
      thslp_zdiffu        = 0.02
      thhgtd_zdiffu       = 125.
      hbot_qvsubstep      = 32.
      htop_moist_proc     = 22500.
    [[[turb_vdiff_nml]]]
      fsl                    = 0.8    # for lowest model layer thickness of 20m
      pr0                    = 0.85   # 0.85 # default: 0.68; neutral limit Prandtl number (0.6 to 1.0)
      f_theta_limit_fraction = 0.13
      f_theta_decay          = 1.0    # default: 4.0
    [[[dynamics_nml]]]
      iequations          = 3       # 3=non-hydrost. atm.
      divavg_cntrwgt      = 0.50
      lcoriolis           = true
    [[[diffusion_nml]]]
      hdiff_order      = 5
      itype_vn_diffu   = 1
      itype_t_diffu    = 2
      hdiff_efdt_ratio = 24.0       # change from default 36.0 to 24.0
      hdiff_smag_fac   = 0.025      # change from default 0.015 to 0.025
      lhdiff_vn        = true
      lhdiff_temp      = true
    [[[interpol_nml]]]
      nudge_zone_width = 8
      lsq_high_ord     = 3
      l_intp_c2l       = true
      l_mono_c2l       = true
    [[[transport_nml]]]
      ivadv_tracer =  3 ,  3 ,  3 ,  3 ,  3
      itype_hlimit =  3 ,  4 ,  4 ,  4 ,  4,  4
      ihadv_tracer = 20 , 20 , 20 , 20 , 20, 20
    [[[nwp_phy_nml]]]
      inwp_gscp         = 1
      inwp_convection   = 1
      inwp_radiation    = 4 # 1: rrtm (old), 4: ecrad
      inwp_cldcover     = 1
      inwp_turb         = 6 # 6: VDIFF, 1: turbtran
      inwp_satad        = 1
      inwp_sso          = 1
      inwp_gwd          = 1
      inwp_surface      = 2 # 2: JSBACH, 1: terra
      icapdcycl         = 3 # apply CAPE modification to improve diurnalcycle over tropical land (optimizes NWP scores)
      latm_above_top    = false # the second entry refers to the nested domain (if present)
      efdt_min_raylfric = 7200.
      itype_z0          = 2
      icpl_o3_tp        = 1
      icpl_aero_conv    = 0 # 1 if irad_aero=6 or 9 is used - 0 for irad_aero=12
      icpl_aero_gscp    = 0 # 1 if irad_aero=6 or 9 is used - 0 for irad_aero=12
      dt_rad            = $ATMO_RADIATION_TIME_STEP
      dt_conv           = $ATMO_TIME_STEP_SEC
      dt_sso            = $ATMO_TIME_STEP_SEC
      dt_gwd            = $ATMO_TIME_STEP_SEC
      dt_ccov           = $ATMO_TIME_STEP_SEC
    [[[nwp_tuning_nml]]]
      tune_gust_factor  = 7.0                       # neu ab L130_030 nach Trang
      max_calibfac_clcl = 2                         # neu ab L130_030 nach Trang
      itune_albedo      = 0                         # somewhat reduced albedo (w.r.t. MODIS data) over Sahara in order to reduce cold bias
      tune_zceff_min    = 0.025                     # ** default value to be used for R3B7; use 0.025 for R2B6
      tune_gkdrag       = 0.05                      # gkdrag:  0.09 (R3B7),  0.075 (R2B6) -> estimate: 0.05 - 0.055 (R2B4)
      tune_gkwake       = 1.0                       # gkwake:  1.8  (R3B7),  1.5   (R2B6) -> estimate: 1.0  - 1.1   (R2B4)
      tune_gfrcrit      = 0.55                      # gfrcrit: 0.333 (R3B7), 0.425 (R2B6) -> estimate: 0.55 - 0.6   (R2B4)
      tune_dust_abs     = 1.
      tune_box_liq_asy  = 3.25                      # oper global: 3.0 , oper D2: 3.25, default: 2.5
      tune_box_liq      = 0.05
      tune_rcucov       = 0.075                     # neu ab L130_030 nach Trang
      tune_rhebc_land   = 0.825                     # neu ab L130_030 nach Trang
      lcalib_clcov      = false                     # turn off TCC, HCC, MCC, LCC tuning
      tune_entrorg      = 1.5e-3                    # default: 1.95e-3; Entrainment parameter valid for dx=20 km
      tune_zvz0i        = 1.2                       # default: 0.85   ; Terminal fall velocity of ice
      tune_gfluxlaun    = 2.5e-3                    # default value
      tune_gcstar       = 2.                        # default value
    [[[lnd_nml]]]
      ntiles          = 1
      lseaice         = true
      sstice_mode     = 6
      sst_td_filename = "sst_inst_mode.nc"
      ci_td_filename  = "sic_inst_mode.nc"
      lprog_albsi     = true             # sea-ice albedo is computed prognostically
    [[[radiation_nml]]]
      isolrad              = 2           # new from L130_30 after Trang
      ecrad_data_path      = "./ecrad_data"
      direct_albedo_water  = 3
      albedo_whitecap      = 1
      albedo_type          = 1           # 1: Albedo computed by jsbach, 2: Modis Albedo
      irad_aero            = 15
      izenith              = 4           # 4: NWP default, 3: no annual cycle
      irad_o3              = 5
      irad_co2             = 4           # 4: from greenhouse gas scenario
      irad_ch4             = 4           # 4: from greenhouse gas scenario
      irad_n2o             = 4           # 4: from greenhouse gas scenario
      irad_cfc11           = 4           # 4: from greenhouse gas scenario
      irad_cfc12           = 4           # 4: from greenhouse gas scenario
    [[[extpar_nml]]]
      n_iter_smooth_topo      = 1
      heightdiff_threshold    = 3000.
      hgtdiff_max_smooth_topo = 750.,750.,
      itype_lwemiss           = 1        # (needs updated Extpar data with lw emissivity)
      read_nc_via_cdi         = true
    [[[output_nml atm_2d]]]
      ml_varlist = pres_msl, pres_sfc, sod_t, sou_t, thb_t, t_s, clct, tot_prec_rate, tqv, tqv_dia, tqc_dia, tqi_dia, umfl_s, vmfl_s, sp_10m, t_2m, sob_t, thb_t, sob_s, thb_s, shfl_s, lhfl_s, qhfl_s, snow_con_rate, snow_gsp_rate, ice_gsp_rate, qifl_s, t_seasfc, fr_land, fr_seaice, t_ice, h_ice
    [[[output_nml atm_3d]]]
      ml_varlist = pres, geopot, temp, u, v, qv, rh, clc, tot_qc_dia, tot_qi_dia
    [[[output_nml atm_mon]]]
      ml_varlist = tas_gmean, rsdt_gmean, rsut_gmean, rlut_gmean, radtop_gmean, prec_gmean, evap_gmean, pme_gmean
    [[[output_nml atm_dbg]]]
      .hide = true
    [[[output_nml atm_vgrid]]]
      .hide = true
    [[[aes_phy_nml]]]
      .hide = true
    [[[aes_rad_nml]]]
      .hide = true
    [[[aes_gwd_nml]]]
      .hide = true
    [[[aes_sso_nml]]]
      .hide = true
    [[[aes_vdf_nml]]]
      .hide = true
    [[[aes_cnv_nml]]]
      .hide = true
    [[[aes_cld_nml]]]
      .hide = true
    [[[aes_cov_nml]]]
      .hide = true
    [[[ccycle_nml]]]
      .hide = true
    [[[dbg_index_nml]]]
      .hide = true

  [[NAMELIST_lnd]]
    [[[jsb_model_nml]]]
      enforce_water_budget = error # water balance errors levels: error, logging, ignore
    [[[jsb_hydro_nml]]]
      l_organic = true
    [[[jsb_hd_nml]]]
      routing_scheme          = full # 'zero': simple scheme with zero runoff everywhere
      diag_water_budget       = false

[files]

  [[atmosphere]]
    [[[model]]]
      [[[[external]]]]
        .sub_dir   = externals/ecrad
        ecrad_data = data
    [[[mapped]]]
      [[[[initial]]]]
        .sub_dir = initial_condition/r0001
        ifs2icon.nc = ifs2icon_1979010100_${ATMO_GRID_TYPE}_G.nc
    [[[independent]]]
      .base_dir = $ATMO_INPUT_DIR/common
      bc_greenhouse_gases.nc = greenhouse_gases/greenhouse_historical_plus.nc
      [[[[volcano_aerosols]]]]
        .offsets = -1, 0, 1
        .set label = 1979, 1979:%year, 2015:2014
        .sub_dir = aerosol_volcanic_cmip6
        bc_aeropt_cmip6_volc_lw_b16_sw_b14_%year.nc = bc_aeropt_cmip6_volc_lw_b16_sw_b14_$${label}.nc
      [[[[solar_irradiance]]]]
        .sub_dir = solar_radiation
        bc_solar_irradiance_sw_b14.nc = swflux_14band_cmip6_1850-2299-v3.2.nc
      [[[[plumes]]]]
        .sub_dir = MACv2_simple_plumes_merged
        MACv2.0-SP_v1.nc = MACv2.0-SP-merged-historical-and-SSP2-45_v1.nc

  [[land]]
    [[[mapped]]]
      .sub_dir = $ATMO_GRID_ID/land/r0101
      ic_land_soil.nc = ic_land_soil.nc
      bc_land_frac.nc = bc_land_frac${.pft_tag}_$LAND_REFERENCE_YEAR.nc
      bc_land_phys.nc = bc_land_phys.nc
      bc_land_soil.nc = bc_land_soil.nc
      bc_land_sso.nc = bc_land_sso.nc
    [[[hydro]]]
      .hide = true

  [[hydro]]
    .base_dir = $LAND_INPUT_DIR
    .sub_dir = $ATMO_GRID_ID/land/r0101
    bc_land_hd.nc = hdpara_r2b4_${ATMO_GRID_ID}_sc_hfrac_s_v1.nc

  [[special]]
    .base_dir = $ATMO_INPUT_DIR
    [[[extpar]]]
      .sub_dir = ${ATMO_GRID_ID}/land/r0101
      extpar_icon_grid_G.nc = icon_extpar4jsbach_${ATMO_GRID_ID}_20240827_tiles_jsb.nc
    [[[aerosols]]]
      .sub_dir = ${ATMO_GRID_ID}/aerosol_kinne/r0100
      bc_aeropt_kinne_lw_b16_coa.nc = .
      bc_aeropt_kinne_sw_b14_coa.nc = .
    [[[aerosols_time]]]
      .offsets   = -1, 0, 1
      .set label = %year, 2015:2014
      .sub_dir   = ${ATMO_GRID_ID}/aerosol_kinne/r0100
      bc_aeropt_kinne_sw_b14_fin_%year.nc = bc_aeropt_kinne_sw_b14_fin_$${label}.nc
    [[[ocean_surface]]]
      .sub_dir  = $ATMO_GRID_ID/sst_and_seaice
      sic_inst_mode.nc = SeaIce_CMIP_PCMDI-AMIP-1-1-7_197801-202012_daily_${ATMO_GRID_ID}_${ATMO_GRID_TYPE}_G.nc
      sst_inst_mode.nc = SST_CMIP_PCMDI-AMIP-1-1-7_197801-202012_daily_${ATMO_GRID_ID}_${ATMO_GRID_TYPE}_G.nc
    [[[ozone]]]
      .offsets   = -1, 0, 1
      .set label = %year, 2015:2014
      .sub_dir   = $ATMO_GRID_ID/ozone/r0100
      bc_ozone_%year.nc = bc_ozone_historical_$${label}.nc
#
# Initialize atmosphere only from standard climatology
#
[jobs]
  [[run]]
    nodes = 20
    share_nodes = true
    time_limit = 00:30:00
  [[run_start]]
    .lrestart = false

    [[[namelists]]]

      [[[[icon_master.namelist]]]]
        [[[[[master_nml]]]]]
          lrestart = ${.lrestart}
      [[[[NAMELIST_lnd]]]]
        [[[[[jsb_hd_nml]]]]]
          read_initial_reservoirs = true

    [[[files]]]

      [[[[atmosphere]]]]
        [[[[[restart_data]]]]]
          restart_atm_DOM01_data.nc =
        [[[[[restart]]]]]
          restart_atm_DOM01.nc =
      [[[[hydro]]]]
        ic_land_hd.nc = hdstart_r2b4_${ATMO_GRID_ID}_sc_hfrac_s_v1.nc

  [[post]]
    tasks = 8
    time_limit = 00:10:00
  [[mon]]
    tasks = 4
    time_limit = 00:05:00

[output]
  atm_dbg_ml = false
  atm_vgrid_ml = false
