#
# AMIP setup using AES pyhsics
#

VERSION_ = $$Id: amip-R2B4.config 1 2021-11-10 17:43 m212005 $$

SCENARIO = ssp370

# Atmosphere setup
ATMO_GRID_ID = 0054
ATMO_GRID_TYPE = R02B08
ATMO_LEVELS = 90

ATMO_TIME_STEP = PT60S
ATMO_RADIATION_TIME_STEP = PT20M
ATMO_DYNAMICS_SUBSTEPS = 5
ATMO_BLOCK_SIZE = 32

# Land setup
WITH_LAND = true
LAND_WITH_HD = false
LAND_WITH_LAKES = false
LAND_REFERENCE_YEAR = 1976

# Switch off ocean
WITH_OCEAN = false
WITH_OBGC = false

# Variables that needs to be unset to avoid issues with DEFAULT.config
OCEAN_GRID_TYPE =
OCEAN_TIME_STEP =
OCEAN_BLOCK_SIZE =
OCEAN_GRID_ID =
OBGC_EUPHOTIC_LEVELS =
COUPLER_TIME_STEP =

# Time control
INITIAL_DATE    = 1979-01-01
FINAL_DATE      = 1982-01-01
INTERVAL        = P3M

# Output control
OUTPUT_INTERVAL = P1D
FILE_INTERVAL   = P1M


[namelists]

  [[icon_master.namelist]]
    [[[master_nml]]]
      read_restart_namelists = true
    [[[master_time_control_nml]]]
      experimentstartdate = $INITIAL_DATE

  [[NAMELIST_atm]]
    [[[parallel_nml]]]
      iorder_sendrecv = 3
      num_io_procs = 2
      num_prefetch_proc =
      num_restart_procs = 10
      pio_type =
      nblocks_c = 0
      nproma_sub = 32
      io_proc_chunk_size = 46
      io_process_stride = 8
    [[[dynamics_nml]]]
      lmoist_thdyn = true
    [[[run_nml]]]
      timers_level = 10
      profiling_output = 1
      restart_filename = ${EXP_ID}_restart_atm_<rsttime>.mfr
    [[[extpar_nml]]]
      itype_lwemiss =
    [[[initicon_nml]]]
    [[[nonhydrostatic_nml]]]
      damp_height = 44000.
      rayleigh_coeff = 1
      divdamp_order = 24
      divdamp_trans_end = 17500
      divdamp_trans_start = 12500
      divdamp_type = 32
      exner_expol = 0.333
      hbot_qvsubstep = 16000.
      htop_moist_proc = 22500.
      iadv_rhotheta = 2
      igradp_method = 3
      itime_scheme = 4
      ivctype = 2
      l_zdiffu_t = true
      thhgtd_zdiffu = 125.
      thslp_zdiffu = 0.02
    [[[interpol_nml]]]
      rbf_scale_mode_ll =
    [[[sleve_nml]]]
      min_lay_thckn = 25.
      top_height = 75000.
      flat_height = 22500.
      htop_thcknlimit = 14000.
      max_lay_thckn = 400.
    [[[aes_phy_nml]]]
      aes_phy_config(1)%dt_mig = $ATMO_TIME_STEP
      aes_phy_config(1)%lamip = true
      aes_phy_config(1)%use_shflx_adjustment = false
      aes_phy_config(1)%iqneg_d2p = 2
      aes_phy_config(1)%iqneg_p2d = 2
    [[[aes_rad_nml]]]

      aes_rad_config(1)%isolrad = 1
      aes_rad_config(1)%irad_co2 = 3
      aes_rad_config(1)%irad_ch4 = 13
      aes_rad_config(1)%irad_n2o = 13
      aes_rad_config(1)%irad_o3 = 5
      aes_rad_config(1)%irad_cfc11 = 3
      aes_rad_config(1)%irad_cfc12 = 3
      aes_rad_config(1)%irad_aero = 13
      aes_rad_config(1)%vmr_co2 =
      aes_rad_config(1)%vmr_ch4 =
      aes_rad_config(1)%vmr_n2o =
      aes_rad_config(1)%lyr_perp =
      aes_rad_config(1)%yr_perp =
      aes_rad_config(1)%inhom_lts = true
      aes_rad_config(1)%inhom_lts_max = 0.725
    [[[io_nml]]]
      lnetcdf_flt64_output = false
      restart_write_mode = joint procs multifile
      write_initial_state =
    [[[dbg_index_nml]]]
      .hide = true

    [[[aes_cop_nml]]]
      aes_cop_config(1)%cinhomi = 0.6
      aes_cop_config(1)%cinhoml = 0.4
      aes_cop_config(1)%cinhoms = 0.6
      aes_cop_config(1)%cn1lnd = 50.0
      aes_cop_config(1)%cn1sea = 50.0
      aes_cop_config(1)%cn2lnd = 220.0
      aes_cop_config(1)%cn2sea = 100.0
    [[[aes_cov_nml]]]
      aes_cov_config(1)%cqx = 1.e-6
    [[[aes_vdf_nml]]]
      aes_vdf_config(1)%dissipation_factor = 1.3
      aes_vdf_config(1)%energy_type = 2
      aes_vdf_config(1)%pr0 = 0.7
      aes_vdf_config(1)%turb = 2
      aes_vdf_config(1)%use_tmx = true
    [[[cloud_mig_nml]]]
    [[[diffusion_nml]]]

    # Define output files
    # -------------------
    # Default settings for 'output_nml *'
    [[[output_nml]]]
      filename_format = <output_filename>_<datetime2>
      operation = mean

    [[[output_nml atm_2d_P1D_ml]]]
      ml_varlist = tas, cllvi, clivi, hfls, hfss, pr, prw, prls, prlr, pr_rain, pr_ice, pr_snow, pr_grpl, qgvi, qrvi, qsvi, rlds, rlus, rlut, rsds, rsdt, rsus, rsut, sfcwind, sic, sit, tauu, tauv, evspsbl, uas, vas, ps, ts, psl, clt, qv2m, pres_msl, pres_sfc

    [[[output_nml atm_3d_qp_ml]]]
      ml_varlist = ta, ua, va, hus


    [[[sea_ice_nml]]]
      albedow_sim = 0.10
      albi = 0.70
      albim = 0.68
      albs = 0.81
      albsm = 0.77
      cd_io = 5.5e-3
      delta_min = 2.0e-09
      evp_rheol_steps = 240
      i_ice_dyn = 1
      i_ice_therm = 1
      leadclose_1 = 0.25
      leadclose_2n = 0.666
      luse_replacement_pressure = true
    [[[transport_nml]]]
      ihadv_tracer = 20, 20, 20, 20, 20, 20
      itype_hlimit = 3, 4, 4, 4, 4, 4
      ivadv_tracer = 3, 3, 3, 3, 3, 3
      tracer_names = hus, clw, cli, qr, qs, qg

  [[NAMELIST_lnd]]
    [[[jsb_assimi_nml]]]
      active = false
    [[[jsb_carbon_nml]]]
      active = false
      bc_filename = bc_land_carbon.nc
      ic_filename = ic_land_carbon.nc
      read_cpools = false
    [[[jsb_disturb_nml]]]
      active = false
      bc_filename = bc_land_phys.nc
      fire_algorithm = 1
      ic_filename = ic_land_soil.nc
      lburn_pasture = false
      windbreak_algorithm = 1
    [[[jsb_fuel_nml]]]
      active = false
      fuel_algorithm = 1
    [[[jsb_hydro_nml]]]
      bc_filename = bc_land_soil.nc
      bc_sso_filename = bc_land_sso.nc
      ic_filename = ic_land_soil.nc
      l_organic = false
      l_socmap = false
      l_soil_texture = true
      snow_depth_max =
    [[[jsb_model_nml]]]
      fract_filename = bc_land_frac.nc
      init_from_ifs = true
      use_lakes = true
      use_tmx = true
      usecase = jsbach_lite
    [[[jsb_pheno_nml]]]
      bc_filename = bc_land_phys.nc
      ic_filename = ic_land_soil.nc
      scheme = climatology
    [[[jsb_rad_nml]]]
      bc_filename = bc_land_phys.nc
      ic_filename = ic_land_soil.nc
      use_alb_veg_simple = true
    [[[jsb_seb_nml]]]
      bc_filename = bc_land_phys.nc
      ic_filename = ic_land_soil.nc
    [[[jsb_sse_nml]]]
      bc_filename = bc_land_soil.nc
      ic_filename = ic_land_soil.nc
      l_dynsnow = true
      l_freeze = true
      l_heat_cap_dyn = false
      l_heat_cap_map = false
      l_heat_cond_dyn = false
      l_heat_cond_map = false
      l_snow = true
      l_soil_texture = true
      l_supercool = false
    [[[jsb_turb_nml]]]
      bc_filename = bc_land_phys.nc
      ic_filename = ic_land_soil.nc
      max_ini_rough_m = 1.0

[files]

  [[atmosphere]]
    [[[model]]]
      [[[[data]]]]
        .sub_dir = data
        lsdata.nc =
        ECHAM6_CldOptProps.nc =
        rrtmgp-cloud-optics-coeffs-lw.nc = ECHAM6_CldOptProps_rrtmgp_lw.nc
        rrtmgp-cloud-optics-coeffs-sw.nc = ECHAM6_CldOptProps_rrtmgp_sw.nc
      [[[[rrtmgp]]]]
        .sub_dir = data
        coefficients_lw.nc = rrtmgp-gas-lw-g128.nc
        coefficients_sw.nc = rrtmgp-gas-sw-g112.nc
    [[[independent]]]
      .sub_dir = common
      .method = ln -s
      bc_greenhouse_gases.nc = greenhouse_gases/greenhouse_$SCENARIO.nc
      [[[[solar_irradiance]]]]
        .sub_dir = solar_radiation
        bc_solar_irradiance_sw_b14.nc = swflux_14band_cmip6_1850-2299-v3.2.nc
    [[[mapped]]]
      .method = ln -s
      [[[[initial]]]]
        .sub_dir = initial_conditions/r0100
        ifs2icon.nc = ifs2icon_1979010100_${ATMO_GRID_ID}_${ATMO_GRID_TYPE}_G.nc
      [[[[ozone]]]]
        .offsets = -1, 0, 1
        .set label = %year
        .sub_dir = ozone/r0100
        bc_ozone_%year.nc = bc_ozone_historical_$${label}.nc
      [[[[ocean_surface]]]]
        .sub_dir = sst_and_seaice/r0100
        bc_sic.nc = bc_sic_1978-2016.nc
        bc_sst.nc = bc_sst_1978-2016.nc
      [[[[aerosols]]]]
        .sub_dir = aerosol_kinne/r0100
        bc_aeropt_kinne_lw_b16_coa.nc = .
        bc_aeropt_kinne_sw_b14_coa.nc = .
      [[[[aerosols_time]]]]
        .offsets   = -1, 0, 1
        .sub_dir   = aerosol_kinne/r0100
        .set label = %year
        bc_aeropt_kinne_sw_b14_fin_%year.nc = bc_aeropt_kinne_sw_b14_fin_$${label}.nc
    [[[restart]]]
      multifile_restart_atm.mfr = ${EXP_ID}_restart_atm_$${start_stamp}Z.mfr
      restart_atm_DOM01.nc =

  [[land]]
    [[[mapped]]]
      .sub_dir = $ATMO_GRID_ID/land/r0100
      .method = ln -s
      bc_land_frac.nc = .
      bc_land_phys.nc = .
      bc_land_soil.nc = .
      bc_land_sso.nc = .
      ic_land_soil.nc = .


# Initialize atmosphere only from standard climatology
[jobs]
  [[run_start]]
    [[[namelists]]]
      [[[[icon_master.namelist]]]]
        [[[[[jsb_control_nml]]]]]
          restart_jsbach =
        [[[[[master_nml]]]]]
          lrestart =
    [[[files]]]
      [[[[atmosphere]]]]
        [[[[[restart_data]]]]]
          .hide = true
        [[[[[restart]]]]]
          .hide = true
