#--------------------------------------------------------------------------------
#
# Marco Giorgetta, MPI-M
# Check if the original qubicc experiment is reproducibility with respect to:
# - adding a restart
# - changing the block and inner loop length nproma
# - changing the number of mpi  processes (distrib. memory parallelization)
# - changing the number of openmp threads (shared   memory parallelization)
#
exp_original=atm_qubicc_test
#
#--------------------------------------------------------------------------------
#
# 1. Define the experiment and the files to be checked

# EXPERIMENT contains the name of the modified experiment
#
export EXPERIMENT=${exp_original}

# TYPES is a list of names identifying the files <EXPERIMENT>_<TYPE>_<DATE>.<FORMAT> to be checked.
#
export TYPES=''
TYPES="$TYPES pfull_ml ta_ml rho_ml ua_ml va_ml wa_ml"                                                      # atmospheric state dynamics
TYPES="$TYPES hus_ml clw_ml cli_ml qr_ml qs_ml qg_ml"                                                       # atmospheric state tracers
TYPES="$TYPES atm2d_ml"                                                                                     # atmospheric state, 2d, many vars.
TYPES="$TYPES flx2d_ml"                                                                                     # parametr.  fluxes, 2d, many vars.
TYPES="$TYPES ddt_ua_dyn_ml ddt_ua_adv_ml ddt_ua_cor_ml ddt_ua_dmp_ml ddt_ua_hdf_ml ddt_ua_pgr_ml"          # tendencies, dynamics, ua
TYPES="$TYPES ddt_va_dyn_ml ddt_va_adv_ml ddt_va_cor_ml ddt_va_dmp_ml ddt_va_hdf_ml ddt_va_pgr_ml"          # tendencies, dynamics, va
TYPES="$TYPES tend_ta_rlw_ml tend_ta_rsw_ml"                                                                # tendencies, radiation
TYPES="$TYPES tend_ta_vdf_ml tend_ua_vdf_ml tend_va_vdf_ml tend_hus_vdf_ml tend_clw_vdf_ml tend_cli_vdf_ml" # tendencies, vertical diffusion
TYPES="$TYPES tend_ta_mig_ml                               tend_hus_mig_ml tend_clw_mig_ml tend_cli_mig_ml" # tendencies, cloud microphysics

# DATES is a list of dates identifying the files <EXPERIMENT>_<TYPE>_<DATE>.<FORMAT> to be checked.
#
export DATES="19790101T000040Z 19790101T000120Z 19790101T000200Z 19790101T000240Z 19790101T000320Z 19790101T000400Z" # dates of time steps

# RESTART_DATE defines the date and time from which restarts should be performed.
#
export RESTART_DATE="19790101T000200Z"

#--------------------------------------------------------------------------------
#
# 2. Define the checksuite mode

builder="unknown"
[[ $BB_NAME ]] && builder=$(echo ${BB_NAME} | tr '[:upper:]' '[:lower:]')

case $builder in
    levante_gpu*) export MD='rm'   ;; # GPU setup uses nblocks_c=1 -> no nproma test, and no OMP parallelization -> no omp test
    *)            export MD='rnmo' ;;
esac

#--------------------------------------------------------------------------------
#
# 3. Launch the checksuite

rundir=`pwd`
cd checksuite.icon-dev

./icon-dev.checksuite
STATUS=$?

check_final_status $STATUS "$EXPERIMENT"

#--------------------------------------------------------------------------------
exit
