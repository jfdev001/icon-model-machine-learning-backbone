# set experiment specific variables

base_exp=atm_qubicc_test_update_base

check_script=checksuite.icon-dev/check.${base_exp%_test_update_base}

# TYPES is a list of names identifying the files <EXPERIMENT>_<TYPE>_<DATE>.<FORMAT> to be checked.
# get TYPES from the main check script
grep 'TYPES=' $check_script > ${check_script}_TYPES
. ./${check_script}_TYPES

update_file_ids=$TYPES

. ./add_refgen_routines

# move data for update test
store_model_output

status=$?
echo $status > pp.${EXPNAME}.run.final_status
exit $status
