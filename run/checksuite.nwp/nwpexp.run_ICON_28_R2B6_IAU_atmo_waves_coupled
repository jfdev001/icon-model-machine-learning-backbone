# wave restart file
ln -sf $INDIR/wave/2022110300/icon_waves_grid_0024_R02B06_G_DOM01_restart_wave_20221102T223000Z.nc restart_wave_DOM01.nc

# ----------------------------------------------------------------------
# global namelist settings
# ----------------------------------------------------------------------

# the namelist filename
atmo_namelist=NAMELIST_${EXP}_atm
wave_namelist=NAMELIST_${EXP}_wave

# global timing
start_date="2022-11-03T00:00:00Z"
stop_date="2022-11-03T10:00:00Z"

dtime=360

waveTimeStep="PT6M"              # wave time step
couplingTimeStep="PT6M"         # coupling time step
longcouplingTimeStep="P100Y"     # no coupling (long coupling period)

# the grid parameters
