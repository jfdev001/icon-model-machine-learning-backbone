# Fill model list
# -------------------
#
namelist_list[0]="$atmo_namelist"
modelname_list[0]="atmo"
modeltype_list[0]=1
minrank_list[0]=$atm_min_rank
maxrank_list[0]=$atm_max_rank
incrank_list[0]=$atm_inc_rank
#
namelist_list[1]="$wave_namelist"
modelname_list[1]="wave"
modeltype_list[1]=98
minrank_list[1]=$wave_min_rank
maxrank_list[1]=$wave_max_rank
incrank_list[1]=$wave_inc_rank
model_do_restart_list[1]="for_init"   # initialize model from restart file

# YAC coupling library configuration
#-----------------------------------------------------------------------------
atm_lag=-14   # time lags in unit of time steps
wave_lag=-14  # in order to start coupling at the shifted start date

cat > coupling_${EXP}.yaml << EOF
definitions:
  components:
    atm: &atm
      component: ${modelname_list[0]}
      grid: icon_atmos_grid
    wave: &wave
      component: ${modelname_list[1]}
      grid: icon_waves_grid
  atm2wave: &atm2wave
    source: *atm
    target: *wave
    time_reduction: none
    src_lag: ${atm_lag}
    tgt_lag: ${wave_lag}
  wave2atm: &wave2atm
    source: *wave
    target: *atm
    time_reduction: none
    src_lag: ${wave_lag}
    tgt_lag: ${atm_lag}
  interp_stacks:
    hcsbb_interp_stack: &hcsbb_interp_stack
      interpolation:
        - bernstein_bezier
        - nnn:
            n: 4
            weighted: arithmetic_average
        - fixed:
            user_value: -999.9
timestep_unit: ISO_format
calendar: proleptic-gregorian
coupling:
  - <<: [ *atm2wave, *hcsbb_interp_stack ]
    coupling_period: ${couplingTimeStep}
    field: [zonal_wind_in_10m,
            meridional_wind_in_10m,
            fraction_of_ocean_covered_by_sea_ice]
  - <<: [ *wave2atm, *hcsbb_interp_stack ]
    coupling_period: ${couplingTimeStep}
    field: [roughness_length]
EOF

# yaml files for yac
# ------------------
ln -sf coupling_${EXP}.yaml     coupling.yaml

