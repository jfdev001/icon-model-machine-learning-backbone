#=======================================================================
#
# R2B6 NWP atmosphere coupled to R2B6 wave
#
# nwpexp.run_ICON_28_R2B6_IAU_atmo_waves_coupled
#
# Basic test case for ICON-NWP coupled to ICON-WAVE.
# ICON-NWP starts from ununitialized analysis with IAU, while ICON-WAVE starts
# from a restart file.
#
# The purpose is the technical testing of
# - the coupling of components with distinct start times
#     (due to IAU, the atm component starts prior to the wave component)
# - the component-wise initialization from restart
#     (only one component starts from restart file while the other used IAU)
#
author_list="Daniel Reinert and Mikhail Dobrynin"
#
# Some preset environment variables:
# nproma = blocking length for array dimensioning and inner loop lengths
# mpi_procs_pernode = Number of mpi processes per node
# proc0_shift
#=======================================================================

# ----------------------------------------------------------------------
# path definitions
# ----------------------------------------------------------------------

make_and_change_to_experiment_dir # function in ../add_run_routines

# Combine START and MODEL if START_MODEL is not already set.
# START_MODEL is used to ease the execution of a machine that uses a complex
# mpirun command with multiple binaries
START_MODEL="${START_MODEL:=$START $MODEL}"

# set icon_data_poolFolder
icon_data_poolFolder="${icon_data_rootFolder:-/pool/data/ICON}/buildbot_data/nwp"

export PATH=${PATH}:~routfor/routfox/bin

# base directory for ICON sources, binary and auxilary data:
ICONDIR="${basedir}" # basedir can be set with create_target_header

# experiment identifier for output files
EXP="couple_atm_wave_R2B6_28"    # experiment identifier

# root directory for input data
DATAROOT="${icon_data_poolFolder}/Checksuite_data/"

# atmo
GRIDDIR="${icon_data_poolFolder}/grids/public/edzw"
# GRIDDIR links to /hpc/rwork0/routfor/routfox/icon/grids/public/edzw on RCL
EXTPDIR="$GRIDDIR" # external parameter directory

# waves
GRIDDIR_waves=${DATAROOT}/ICON-waves
# directory with external parameter data:
EXTPDIR_waves=${DATAROOT}/ICON-waves

# absolute path to input directory
INDIR=${DATAROOT}/InidataExp28/

# ----------------------------------------------------------------------
# Basic model configuration
# ----------------------------------------------------------------------

# nproma = blocking length for array dimensioning and inner loop lengths
nproma_atm=$nproma
nproma_wave=$nproma

# number of io/restart/prefetch/radar procs
#
num_atm_io_procs=2
num_atm_restart_procs=0
num_atm_prefetch_proc=0
num_atm_io_procs_radar=0

num_wave_io_procs=1
num_wave_restart_procs=0
num_wave_prefetch_proc=0
num_wave_io_procs_radar=0

# ----------------------------------------------------------------------
# MPI variables
# ----------------------------------------------------------------------
# NEC has PPN=NE*CPE mpi processes (OMP_NUM_THREADS=1)
# they will be devided in wave and atmosphere
#
case $use_target in
    rcl)
        mpi_total_procs=${PPN}
        ;;
esac

if [ $mpi_total_procs -lt 2 ] ; then
  check_error 0 "This setup requires at least 2 mpi processes. Exit"
fi

# Number of mpi processes per node
# Please note that we do not expect the processes to be distributed
# over nodes in a particular manner. atm_per_node and wave_per_node
# are used only the specify the relative amount of available processes
# that are used by atm versus wave.
#
wave_per_node=$((mpi_procs_pernode/4))
atm_per_node=$((mpi_procs_pernode - wave_per_node))
num_atm_procs=$((no_of_nodes * atm_per_node))
num_wave_procs=$((no_of_nodes * wave_per_node))

#-----------------------------------------------------------------
# Coupling section
#-----------------------------------------------------------------

ICON_COMPONENT1_proc0_shift=$proc0_shift  # proc0_shift set by create_target_header
ICON_COMPONENT2_proc0_shift=$proc0_shift

# Please note that io/restart/prefetch/radar procs are offloaded to VH procs for proc0_shift>0.
# Otherwise, they are taken from the pool of VE processes. This must be taken into account,
# when computing the total number of processes (VH + VE).
#
if (( ICON_COMPONENT1_proc0_shift > 0 )); then
  tot_atm_procs=$((num_atm_procs + num_atm_io_procs + num_atm_restart_procs + num_atm_prefetch_proc + num_atm_io_procs_radar + ICON_COMPONENT1_proc0_shift))
else
  tot_atm_procs=$((num_atm_procs))
fi

if (( ICON_COMPONENT2_proc0_shift > 0 )); then
  tot_wave_procs=$((num_wave_procs + num_wave_io_procs + num_wave_restart_procs + num_wave_prefetch_proc + num_wave_io_procs_radar + ICON_COMPONENT2_proc0_shift))
else
  tot_wave_procs=$((num_wave_procs))
fi


echo "============================================"
echo " #configinfo#  number of nodes: $no_of_nodes"
echo " #configinfo#  OMP_NUM_THREADS = $OMP_NUM_THREADS"
echo " #configinfo#  mpi_procs_pernode = $mpi_procs_pernode"
echo " #configinfo#  mpi_total_procs = $mpi_total_procs"
echo " #configinfo#  atm_per_node = $atm_per_node"
echo " #configinfo#  wave_per_node = $wave_per_node"
echo " #configinfo#  num_atm_procs = $num_atm_procs (excl. io, restart, prefetch procs)"
echo " #configinfo#  num_wave_procs = $num_wave_procs (excl. io, restart, prefetch procs)"
echo " #configinfo#  tot_atm_procs = $tot_atm_procs (incl. io, restart, prefetch procs)"
echo " #configinfo#  tot_wave_procs = $tot_wave_procs (incl. io, restart, prefetch procs)"
echo " #configinfo#  num_atm_io_procs = $num_atm_io_procs"
echo " #configinfo#  num_wave_io_procs = $num_wave_io_procs"
echo " #configinfo#  num_atm_restart_procs=$num_atm_restart_procs"
echo " #configinfo#  num_wave_restart_procs=$num_wave_restart_procs"
echo " #configinfo#  nproma_atm = $nproma_atm"
echo " #configinfo#  nproma_wave = $nproma_wave"
echo "============================================"


# ----------------------------------------------------------------------
# Split the number of total procs and assign to each component
# ----------------------------------------------------------------------
atm_min_rank=0
atm_max_rank=$(( tot_atm_procs - 1 ))
atm_inc_rank=1
wave_min_rank=$(( atm_max_rank + 1 ))
wave_max_rank=$(( tot_atm_procs + tot_wave_procs - 1 ))
wave_inc_rank=1
#
echo " atm_min_rank="$atm_min_rank "  atm_max_rank="$atm_max_rank
echo "wave_min_rank="$wave_min_rank "wave_max_rank="$wave_max_rank


