#
# Suppress output definitions from DEFAULT.config
#
# This is meant as utility until a solution for output handling is found
#

LAND_OUTPUT = none

[namelists]

  [[NAMELIST_atm]]

    [[[output_nml atm_vgrid]]]
      .hide = true
    [[[output_nml atm_mon]]]
      .hide = true
    [[[output_nml atm_dbg]]]
      .hide = true
    [[[output_nml atm_2d]]]
      .hide = true
    [[[output_nml atm_3d]]]
      .hide = true

    [[[output_nml lnd_mon]]]
      .hide = true

  [[NAMELIST_oce]]

    [[[output_nml oce_mon]]]
      .hide = true
    [[[output_nml oce_P1M_moc]]]
      .hide = true
    [[[output_nml oce_P1M_3d]]]
      .hide = true
    [[[output_nml oce_P1M_2d]]]
      .hide = true
    [[[output_nml oce_P1M_sqr]]]
      .hide = true

    [[[output_nml hamocc_monitor]]]
      .hide = true
    [[[output_nml hamocc]]]
      .hide = true
    [[[output_nml hamocc_sediment]]]
      .hide = true
    [[[output_nml hamocc_3d_tendencies]]]
      .hide = true
    [[[output_nml hamocc_EU_tendencies]]]
      .hide = true
    [[[output_nml hamocc_2d_tendencies]]]
      .hide = true

[jobs]

  [[run_start]]
    [[[namelists]]]
      [[[[NAMELIST_oce]]]]
        [[[[[output_nml oce_fx]]]]]
          .hide = true

  [[mon]]
    [[[tags]]]
      atm_mon = false
      lnd_mon = false
      oce_mon = false
      hamocc_monitor = false

[output]

  atm_vgrid_ml = false
  atm_mon = false
  atm_dbg_ml = false
  atm_2d_ml = false
  atm_3d_ml = false

  lnd_mon = false

  oce_mon = false
  oce_P1M_moc = false
  oce_P1M_3d = false
  oce_P1M_2d = false
  oce_P1M_sqr = false

  hamocc_monitor = false
  hamocc = false
  hamocc_sediment = false
  hamocc_3d_tendencies = false
  hamocc_EU_tendencies = false
  hamocc_2d_tendencies = false

  [[fixed]]
    oce_fx = false
