#--------------------------------------------------------------------------------------------------
#
# Settings to initialize natural land cover change (nlcc)
#

VERSION_ = $$Id: run/standard_options/land/init_nlcc.config 1 2024-11-05 16:20:39Z m221078 $$

# The option is needed to initialize natural land cover change (nlcc; former dynveg)
# in case of
#    - initialized experiments  or
#    - if nlcc was not active in the parent experiment of a restarted run.
#
# The climate and NPP buffers need to be initialized twice, first to calculate
# minimum and maximum monthly mean temperatures, and second to calculate multi
# annual running means of these variables. On the other hand, the initialization
# cannot happen in the first year. We therefore generate special runscripts for
# the second and third year (or multi-year chunk) of the simulation:
# EXP_ID.run_second and EXP_ID.run_third. The scripts are called automatically
# from EXP_ID.run_start and submit the next EXP_ID.run scripts.

[namelists]
  [[NAMELIST_lnd]]
    [[[jsb_nlcc_nml]]]
      active = true

[jobs]
  [[run_start]]
    .trigger = run_second, post # Job submits EXP_ID.run_second (instead of EXP_ID.run)
    [[[namelists]]]
      [[[[NAMELIST_lnd]]]]
        [[[[[jsb_nlcc_nml]]]]]
          init_nlcc = TRUE  # needed in restarted runs if nlcc was not active in parent experiment
          accelerate_nlcc = 0.1  # slow down vegetation dynamics, as climate buffer not yet set
  [[run_second]]
    .extends = run
    .trigger = run_third, post # Job submits EXP_ID.run_third (instead of EXP_ID.run)
    [[[namelists]]]
      [[[[NAMELIST_lnd]]]]
        [[[[[jsb_nlcc_nml]]]]]
          init_running_means = TRUE # initialization of climate buffer
          accelerate_nlcc = 0.1  # slow down vegetation dynamics, as climate buffer not yet set
        [[[[[jsb_assimi_nml]]]]]
          init_running_means = TRUE # initialization of NPP buffer
  [[run_third]]
    .extends = run
    [[[namelists]]]
      [[[[NAMELIST_lnd]]]]
        [[[[[jsb_nlcc_nml]]]]]
          init_running_means = TRUE # initialization of climate buffer
        [[[[[jsb_assimi_nml]]]]]
          init_running_means = TRUE # initialization of NPP buffer
