#--------------------------------------------------------------------------------------------------
#
# Settings to write ICON-LAND stand-alone forcing data during AMIP or fully coupled simulations.
# The default for ICON-Land forcing is daily forcing (P1D)
# but forcing generation at time step level is supported, too.
#

VERSION_ = $$Id: run/standard_options/land/generate_forcing.config 1 2024-11-05 16:20:19Z m221078 $$

LAND_FORCING_GENERATION = true
LAND_FORCING_GENERATION_FREQUENCY = P1D
land_forcing_generation_frequency_is_not_daily = eval("$LAND_FORCING_GENERATION_FREQUENCY" != "P1D")

[namelists]

  [[NAMELIST_atm]]
    .remove += output_land_forcing, output_land_forcing daily

    [[[output_land_forcing]]]
      .extends = output_nml
      output_interval = $LAND_FORCING_GENERATION_FREQUENCY
      output_grid = true
      m_levels = raw('$ATMO_LEVELS')

    [[[output_land_forcing daily]]]
      .hide = $land_forcing_generation_frequency_is_not_daily

    [[[output_nml jsbalone_avg]]]
      .extends = output_land_forcing
      operation = mean
      ml_varlist = ta, tot_prec_rate, ua, va, qv, sob_s, sou_s, thb_s, thu_s

    [[[output_nml jsbalone_min]]]
      .extends = output_land_forcing daily
      operation = min
      ml_varlist = ta

    [[[output_nml jsbalone_max]]]
      .extends = output_land_forcing daily
      operation = max
      ml_varlist = ta

[output]
  jsbalone_ml = true
