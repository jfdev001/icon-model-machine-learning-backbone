#--------------------------------------------------------------------------------------------------
#
# Settings for simulations with anthropogenic land cover change (alcc)
#

VERSION_ = $$Id: run/standard_options/land/with_alcc.config 1 2024-11-05 16:20:39Z m221078 $$

# With this option the alcc process is switched on
#   and the respective annual land use maps are provided.

[namelists]
  [[NAMELIST_lnd]]
    [[[jsb_alcc_nml]]]
      active = true

[files]
  [[land]]
    [[[mapped]]]
      [[[[maps]]]]
        .offsets = 0
        bc_land_frac_11pfts_%year.nc = bc_land_frac${.pft_tag}_%year.nc
