#
# DestinE test output definition (unclear provenience)
#

DESTINE_OUTPUT_ATMO_MODEL_LEVELS = "14,21,25,29,31,35,38,41,46,51,55,58,63,67,71,74,76,78,80,81,83,84,85,87,89,90"

[namelists]

  [[NAMELIST_atm]]

    # Define output files
    # -------------------
    # Default settings for 'output_nml *'
    [[[output_nml]]]
      operation = mean
      filename_format = <output_filename>_<datetime2>

    [[[output_nml atm_2d_PT20M_ml]]]
      ml_varlist = pr, qv2m, rlut, rsds, sfcwind, tas
      output_interval = PT20M
    [[[output_nml atm_2d_PT3H_ml]]]
      ml_varlist = clivi, cllvi, qv2m, hfls, hfss, pr, pres_msl, pres_sfc, prls, prw, qgvi, qrvi, qsvi, rlds, rlus, rlut, rsds, rsdt, rsus, rsut, sfcwind, sic, sit, tas, tauu, tauv, ts, uas, vas
      output_interval = PT3H
    [[[output_nml atm_3d_P1D_1]]]
      m_levels = $DESTINE_OUTPUT_ATMO_MODEL_LEVELS
      ml_varlist = wa, ua, va, rho
      output_interval = P1D
      file_interval   = P1D
    [[[output_nml atm_3d_P1D_2]]]
      m_levels = $DESTINE_OUTPUT_ATMO_MODEL_LEVELS
      ml_varlist = hus, clw, cli
      output_interval = P1D
      file_interval   = P1D
    [[[output_nml atm_3d_P1D_3]]]
      m_levels = $DESTINE_OUTPUT_ATMO_MODEL_LEVELS
      ml_varlist = qg, qr, qs
      output_interval = P1D
      file_interval   = P1D
    [[[output_nml atm_3d_P1D_4]]]
      m_levels = $DESTINE_OUTPUT_ATMO_MODEL_LEVELS
      ml_varlist = ta, pfull, phalf
      output_interval = P1D
      file_interval   = P1D
