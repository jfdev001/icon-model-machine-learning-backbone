# I.3 YAC coupling library configuration
#-----------------------------------------------------------------------------

atm_lag=0
oce_lag=0

# co2_flux and co2_mixing_ratio are listed as transients
# below but are not configured for coupling in the couples
# section. There fields are therefore not considered for
# the search not for the data exchange even if yac_fget and
# yac_fput are called for these fields.
#
# component names in coupling.yaml must (!) match with modelname_list[*]
#
cat > coupling_${EXPNAME}.yaml << EOF
predef:
  interp_stacks:
    nnn_fixed: &nnn_fixed
      interpolation:
        - nnn:
            n: 1
            weighted: arithmetic_average
        - fixed:
            user_value: -999.9
    conserv_interp: &conserv_interp
      interpolation:
        - conservative:
            order: 1
            enforced_conservation: false
            partial_coverage: true
            normalisation: fracarea
        - fixed:
            user_value: -999.9
    source2target: &source2target
      interpolation:
        - source_to_target_map
  time_config: &time_config
    coupling_period: ${couplingTimeStep}
    time_reduction: average
    src_lag: 1
    tgt_lag: 1
  component_configs:
    atm_src: &atm_src
      component: atmo
      grid: icon_atmos_grid
    atm_tgt: &atm_tgt
      component: atmo
      grid: [icon_atmos_grid_1,
             icon_atmos_grid_2,
             icon_atmos_grid_3]
    ocn: &ocn
      component: ocean
      grid: icon_ocean_grid
    atm2ocn: &atm2ocn
      source: *atm_src
      target: *ocn
      <<: [ *time_config ]
    ocn2atm: &ocn2atm
      source: *ocn
      target: *atm_tgt
      <<: [ *time_config ]
      mapping_side: target

timestep_unit: ISO_format
calendar: proleptic-gregorian
coupling:
# ATM -> OCN
  - <<: [ *atm2ocn, *conserv_interp ]
    field: [surface_downward_eastward_stress,
            surface_downward_northward_stress]
  - <<: [ *atm2ocn, *conserv_interp ]
    field: [surface_fresh_water_flux,
            total_heat_flux,
            atmosphere_sea_ice_bundle,
            10m_wind_speed]
#  - <<: [ *atm2ocn, *source2target ]
#    field: [river_runoff]
# OCN -> ATM
  - <<: [ *ocn2atm, *conserv_interp]
    field: [sea_surface_temperature,
            eastward_sea_water_velocity,
            northward_sea_water_velocity,
            ocean_sea_ice_bundle]

EOF

