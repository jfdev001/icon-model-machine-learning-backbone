set -eu

SCRIPT_DIR=$(cd "$(dirname "$0")"; pwd)
ICON_DIR=$(cd "${SCRIPT_DIR}/../.."; pwd)

# make module command available
MODULE_SETTINGS=". ${MODULESHOME}/init/sh; module purge"

eval "$MODULE_SETTINGS"

MODULES=(
    gpu/default
    hdf5/1.10.5-x86-nvhpc24.7
    netcdf4/4.9.2-x86-nvhpc24.7
    eccodes/experimental/2.36.0-x86-nvhpc24.7
    nvhpc-openmpi3/24.7
    unsupported
    cmake/3.26.4
  )


# We have to override the compilers because the nvhpc module sets them to the wrong values,
# which get picked up by configure :(
BUILD_ENV="export ICON_DIR=$(cd "${SCRIPT_DIR}/../..">/dev/null; pwd); \
${MODULE_SETTINGS} && . \"${SCRIPT_DIR}/module_switcher\"; \
switch_for_module ${MODULES[@]}; \
export CC=mpicc CXX=mpic++ FC=mpif90; \
export LIBRARY_PATH=\${LD_LIBRARY_PATH}; \
export load_runtime_modules=\"apps gpu netcdf4\";"
echo ${BUILD_ENV}

# We need some of the environment variables set by the modules now:
eval "$BUILD_ENV"

# Base dir for (most of) the external libraries on a typical Linux workstation:
LIB_DIRS="/hpc/uhome/uschaett/opt/lib_nvidia-22.7"

MPI_LAUNCH="mpiexec"

# Libs from module system

HDF5_LIBS="-lhdf5_hl -lhdf5 -lhdf5hl_fortran -lhdf5_fortran"

NETCDF_LIBS="-lnetcdff -lnetcdf"

ZLIB_LIBS="-lz"

BLAS_LAPACK_LIBS="-llapack -lblas"

CUDA_LIBS='-lcudart'

STDCPP_LIBS='-lstdc++fs -lstdc++'

ECCODES_LIBS="${ECCODES_LIB_FTN/-lpng}" # The png component does not work.

# Serialbox
SERIALBOX2_INCLUDE="${LIB_DIRS}/serialbox/install/include"
SERIALBOX2_LIBDIR="${LIB_DIRS}/serialbox/install/lib"
SB2PP="python2 ${LIB_DIRS}/serialbox/install/python/pp_ser/pp_ser.py"

SERIALBOX2_STATIC_LINKING="yes" # if "no", try automatic/dynamical lining
if [[ $SERIALBOX2_STATIC_LINKING == no ]]; then
  SERIALBOX2_LIBS='-lSerialboxFortran -lSerialboxC -lSerialboxCore' # dynamical linking, if .so are present.
else
  # Link serialbox statically
  SERIALBOX2_LIBS="${SERIALBOX2_LIBDIR}/libSerialboxFortran.a ${SERIALBOX2_LIBDIR}/libSerialboxC.a ${SERIALBOX2_LIBDIR}/libSerialboxCore.a"
fi

################################################################################


CC="mpicc"
CXX="mpic++"
CFLAGS="-g -O2"
CPPFLAGS="${ECCODES_INCLUDE}"

ICON_CFLAGS='-O2'
ICON_BUNDLED_CFLAGS='-g -O2'

# Fortran compiler wrapper on Linux workstation using OpenMPI
FC="mpif90"
FCFLAGS="-I${HDF5_DIR}/include -I${NETCDF_DIR}/include ${ECCODES_INCLUDE} -I${SERIALBOX2_INCLUDE} \
  -Mpreprocess \
  -Mrecursive \
  -Mallocatable=03 \
  -g \
  -traceback \
  -acc=verystrict \
  -gpu=cc80 \
  -Minfo=accel,inline \
  -D__USE_G2G \
  -Mpcast \
"

ICON_FCFLAGS='-O2'

# The compiler fails to process some of the EMVORADO and DACE source files with
# the default optimization level:
ICON_WORKAROUND1_FCFLAGS="-O1"
ICON_WORKAROUND1_PATH='externals/dace_icon/src_for_icon/mo_rad.f90:externals/emvorado/src_iface_icon/radar_interface.f90'


# NVIDIA CUDA Compiler command
CUDACXX="nvcc"
# NVIDIA CUDA Compiler flags
CUDAFLAGS='--std=c++14 -arch=sm_80 -g -O3'

LDFLAGS=""

LIBS="-Wl,--as-needed ${BLAS_LAPACK_LIBS} ${NETCDF_LIBS} ${HDF5_LIBS} ${ECCODES_LIBS} ${SERIALBOX2_LIBS} ${ZLIB_LIBS} ${CUDA_LIBS} ${STDCPP_LIBS}"

EXTRA_CONFIG_ARGS='--enable-gpu --without-external-yac --disable-rttov '
EXTRA_CONFIG_ARGS+=' --enable-emvorado --enable-dace --enable-fcgroup-WORKAROUND1'
EXTRA_CONFIG_ARGS+=' --disable-loop-exchange --disable-coupling --disable-yaxt --enable-mixed-precision'
EXTRA_CONFIG_ARGS+=' --enable-ecrad --enable-grib2 --disable-rte-rrtmgp --enable-serialization=read'

# Speed up the configuration by disabling MPI checks:
EXTRA_CONFIG_ARGS+=' --disable-mpi-checks'

################################################################################

"${ICON_DIR}/configure" \
BUILD_ENV="${BUILD_ENV}" \
CC="${CC}" \
CXX="${CXX}" \
CFLAGS="${CFLAGS}" \
CPPFLAGS="${CPPFLAGS}" \
ICON_CFLAGS="${ICON_CFLAGS}" \
ICON_BUNDLED_CFLAGS="${ICON_BUNDLED_CFLAGS}" \
ICON_WORKAROUND1_FCFLAGS="${ICON_WORKAROUND1_FCFLAGS}" \
ICON_WORKAROUND1_PATH="${ICON_WORKAROUND1_PATH}" \
FC="${FC}" \
FCFLAGS="${FCFLAGS}" \
ICON_FCFLAGS="${ICON_FCFLAGS}" \
CUDACXX="${CUDACXX}" \
CUDAFLAGS="${CUDAFLAGS}" \
LDFLAGS="${LDFLAGS}" \
LIBS="${LIBS}" \
MPI_LAUNCH="${MPI_LAUNCH}" \
SB2PP="${SB2PP}" \
${EXTRA_CONFIG_ARGS} \
"$@"

for arg in "$@"; do
  case $arg in
    -help | --help | --hel | --he | -h | -help=r* | --help=r* | --hel=r* | --he=r* | -hr* | -help=s* | --help=s* | --hel=s* | --he=s* | -hs*)
      test -n "${EXTRA_CONFIG_ARGS}" && echo '' && echo "This wrapper script ('$0') calls the configure script with the following extra arguments, which might override the default values listed above: ${EXTRA_CONFIG_ARGS}"
      exit 0 ;;
  esac
done

# Copy runscript-related files when building out-of-source:
if test $(pwd) != $(cd "${ICON_DIR}"; pwd); then
  echo "Copying runscript input files from the source directory..."
  rsync -uavz ${ICON_DIR}/run . --exclude='*.in' --exclude='.*'
  rsync -uavz ${ICON_DIR}/externals . --exclude='.git' --exclude='*.f90' --exclude='*.F90' --exclude='*.c' --exclude='*.h' --exclude='*.Po' --exclude='tests' --exclude='*.mod' --exclude='*.o'
  rsync -uavz ${ICON_DIR}/make_runscripts .
  ln -sf ${ICON_DIR}/data
  ln -sf ${ICON_DIR}/vertical_coord_tables
fi
