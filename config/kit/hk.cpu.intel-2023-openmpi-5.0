#!/bin/bash

# ICON
#
# ------------------------------------------
# Copyright (C) 2004-2025, DWD, MPI-M, DKRZ, KIT, ETH, MeteoSwiss
# Contact information: icon-model.org
# See AUTHORS.TXT for a list of authors
# See LICENSES/ for license information
# SPDX-License-Identifier: BSD-3-Clause
# ------------------------------------------

set -eu
unset CDPATH
ulimit -c 0

SCRIPT_DIR=$(cd "$(dirname "$0")"; pwd)
ICON_DIR=$(cd "${SCRIPT_DIR}/../.."; pwd)

BUILDENV_ROOT='/hkfs/home/dataset/datasets/icon/sw/buildenv'
BUILDENV='intel-2023'

INTEL_ROOT='/software/all/toolkit/Intel_OneAPI/compiler/2023.1.0/linux'
MKL_ROOT='/software/all/toolkit/Intel_OneAPI/mkl/2023.1.0'

MKL_LIBS='-lmkl_gf_lp64 -lmkl_sequential -lmkl_core'
MPI_LIBS='-lmpi_usempif08 -lmpi_usempi_ignore_tkr -lmpi_mpifh -lmpi'
HDF5_LIBS='-lhdf5_hl_fortran -lhdf5_fortran -lhdf5'
NETCDF_LIBS='-lnetcdf'
NETCDFF_LIBS='-lnetcdff'
ECCODES_LIBS='-leccodes_f90 -leccodes'
FYAML_LIBS='-lfyaml'

SERIALBOX2_ROOT="${BUILDENV_ROOT}/${BUILDENV}/opt/serialbox"
SERIALBOX2_LIBS='-lSerialboxFortran -lSerialboxC -lSerialboxCore'
SB2PP="/usr/bin/python2 ${SERIALBOX2_ROOT}/python/pp_ser/pp_ser.py"

# Libraries in /usr/lib{,64}
XML2_INCLUDE_DIR='/usr/include/libxml2'
XML2_LIBS='-lxml2'
ZLIB_LIBS='-lz'

# RTTOV: optional feature will be activated if ${RTTOV_ROOT}/lib and ${RTTOV_ROOT}/include
# are readable for the current user! The system installation has restricted permissions
# and only grants read access to users in the 'hk-project-glori-init' group.
RTTOV_ROOT="${BUILDENV_ROOT}/${BUILDENV}/opt/rttov13"
RTTOV_LIBS='-lrttov13'

################################################################################

BUILD_ENV="export LD_LIBRARY_PATH=\"${INTEL_ROOT}/lib:${INTEL_ROOT}/compiler/lib/intel64:${MKL_ROOT}/lib/intel64:${BUILDENV_ROOT}/${BUILDENV}/lib:${BUILDENV_ROOT}/${BUILDENV}/lib64:/usr/lib64\"; export PATH=\"${INTEL_ROOT}/bin/intel64:${BUILDENV_ROOT}/${BUILDENV}/bin:/usr/bin\"; unset CPATH C_INCLUDE_PATH CPLUS_INCLUDE_PATH INCLUDE LIBRARY_PATH;"

CC="${INTEL_ROOT}/bin/intel64/icc"
FC="${INTEL_ROOT}/bin/intel64/ifort"
AR="${INTEL_ROOT}/bin/intel64/xiar"

ARCH="-m64 -march=core-avx2 -mtune=core-avx2"
FCFLAGS="-I${INTEL_ROOT}/include -I${BUILDENV_ROOT}/${BUILDENV}/include -I${BUILDENV_ROOT}/${BUILDENV}/lib ${ARCH} -g -gdwarf-4 -pc64 -fp-model source"
CFLAGS="-I${INTEL_ROOT}/include -g -gdwarf-4 -qno-opt-dynamic-align ${ARCH} -fma -ip -pc64 -std=gnu99 -I${BUILDENV_ROOT}/${BUILDENV}/include"
CPPFLAGS="-I${INTEL_ROOT}/include -I${BUILDENV_ROOT}/${BUILDENV}/include -I${XML2_INCLUDE_DIR}"

LDFLAGS="-L${INTEL_ROOT}/lib -L${INTEL_ROOT}/compiler/lib/intel64 -L${MKL_ROOT}/lib/intel64 -L${BUILDENV_ROOT}/${BUILDENV}/lib -L${BUILDENV_ROOT}/${BUILDENV}/lib64 -L${SERIALBOX2_ROOT}/lib"
LIBS="-Wl,--disable-new-dtags -Wl,--as-needed ${MPI_LIBS} ${XML2_LIBS} ${ZLIB_LIBS} ${ECCODES_LIBS} ${FYAML_LIBS} ${MKL_LIBS} ${SERIALBOX2_LIBS} ${NETCDFF_LIBS} ${NETCDF_LIBS} ${HDF5_LIBS}"

ICON_FCFLAGS='-DDO_NOT_COMBINE_PUT_AND_NOCHECK -O2 -ftz -qoverride-limits -assume realloc_lhs -align array64byte -fma -ip'
ICON_CFLAGS='-O3 -ftz'
ICON_OCEAN_FCFLAGS='-O3 -assume norealloc_lhs -reentrancy threaded -qopt-report-file=stdout -qopt-report=0 -qopt-report-phase=vec'
ICON_BUNDLED_FCFLAGS='-O3 -ftz -std08'
ICON_BUNDLED_CFLAGS='-O2 -ftz'
ICON_YAC_CFLAGS=${ICON_BUNDLED_CFLAGS}
ICON_CDI_CFLAGS=${ICON_BUNDLED_CFLAGS}
ICON_ECRAD_FCFLAGS='-qno-opt-dynamic-align -no-fma -fpe0'

MPI_LAUNCH="${BUILDENV_ROOT}/${BUILDENV}/bin/mpiexec"

EXTRA_CONFIG_ARGS='--enable-intel-consistency --enable-vectorized-lrtm --enable-ecrad --enable-art --enable-grib2 --enable-emvorado --enable-dace --enable-coupling --enable-dim-swap'
EXTRA_CONFIG_ARGS="${EXTRA_CONFIG_ARGS} --disable-mpi-checks"

# Enable RTTOV if installation is available
if [[ -r "${RTTOV_ROOT}/lib" ]] && [[ -r "${RTTOV_ROOT}/include" ]]; then
    echo "Enabling RTTOV with RTTOV_ROOT=${RTTOV_ROOT}"
    LDFLAGS+=" -L${RTTOV_ROOT}/lib"
    LIBS+=" ${RTTOV_LIBS}"
    FCFLAGS+=" -I${RTTOV_ROOT}/include"
    EXTRA_CONFIG_ARGS+=' --enable-rttov'
else
    echo "Disabling RTTOV due to missing read access for ${RTTOV_ROOT}."
    EXTRA_CONFIG_ARGS+=' --disable-rttov'
fi

################################################################################

"${ICON_DIR}/configure" \
BUILD_ENV="${BUILD_ENV}" \
AR="${AR}" \
CC="${CC}" \
CFLAGS="${CFLAGS}" \
CPPFLAGS="${CPPFLAGS}" \
FC="${FC}" \
FCFLAGS="${FCFLAGS}" \
ICON_BUNDLED_CFLAGS="${ICON_BUNDLED_CFLAGS}" \
ICON_BUNDLED_FCFLAGS="${ICON_BUNDLED_FCFLAGS}" \
ICON_CFLAGS="${ICON_CFLAGS}" \
ICON_ECRAD_FCFLAGS="${ICON_ECRAD_FCFLAGS}" \
ICON_FCFLAGS="${ICON_FCFLAGS}" \
ICON_OCEAN_FCFLAGS="${ICON_OCEAN_FCFLAGS}" \
LDFLAGS="${LDFLAGS}" \
LIBS="${LIBS}" \
MPI_LAUNCH="${MPI_LAUNCH}" \
${EXTRA_CONFIG_ARGS} \
"$@"

for arg in "$@"; do
  case $arg in
    -help | --help | --hel | --he | -h | -help=r* | --help=r* | --hel=r* | --he=r* | -hr* | -help=s* | --help=s* | --hel=s* | --he=s* | -hs*)
      test -n "${EXTRA_CONFIG_ARGS}" && echo '' && echo "This wrapper script ('$0') calls the configure script with the following extra arguments, which might override the default values listed above: ${EXTRA_CONFIG_ARGS}"
      exit 0 ;;
  esac
done

# Copy runscript-related files when building out-of-source:
if test $(pwd) != $(cd "${ICON_DIR}"; pwd); then
  echo "Copying runscript input files from the source directory..."
  rsync -uavz ${ICON_DIR}/run . --exclude='*.in' --exclude='.*' --exclude='standard_*' --exclude=mkexp
  ln -sf -t run/ ${ICON_DIR}/run/{standard_*,mkexp}
  rsync -uavz ${ICON_DIR}/externals . --exclude='.git' --exclude='*.f90' --exclude='*.F90' --exclude='*.c' --exclude='*.h' --exclude='*.Po' --exclude='tests' --exclude='*.mod' --exclude='*.o'
  rsync -uavz ${ICON_DIR}/make_runscripts .
  ln -sf ${ICON_DIR}/data
  ln -sf ${ICON_DIR}/vertical_coord_tables
fi
