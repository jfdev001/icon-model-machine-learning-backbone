set -eu

script_dir=$(cd "$(dirname "$0")"; pwd)
icon_dir=$(cd "${script_dir}/../.."; pwd)

# clear all modules and load modules
#MODULES='Stages/2025 NVHPC/25.3-CUDA-12 ParaStationMPI/5.11.0-1 netCDF-Fortran/4.6.1 ecCodes/2.39.0 libfyaml/.0.9 CMake/3.30.3'
#BUILD_ENV="module --force purge; module load ${MODULES}; module list};"
#eval "${BUILD_ENV}"

NVHPC_ROOT='/p/software/default/stages/2025/software/NVHPC/25.3-CUDA-12'
GCC_ROOT='/p/software/juwels/stages/2025/software/GCCcore/13.3.0'

STDCPP_ROOT=${GCC_ROOT}
STDCPP_LIBS='-lstdc++'

CUDA_ROOT="/p/software/juwelsbooster/stages/2025/software/CUDA/12"
CUDA_LIBS='-lcuda -lcudart'

MPI_ROOT='/p/software/juwels/stages/2025/software/psmpi/5.11.0-1-NVHPC-24.9-CUDA-12'
MPI_extra_ldflags='-L/p/software/juwels/stages/2025/software/pscom/5-default-GCCcore-13.3.0/lib'
MPI_extra_libs='-lpscom'

HDF5_ROOT='/p/software/default/stages/2025/software/HDF5/1.14.5-npsmpic-2024a'
HDF5_LIBS='-lhdf5_hl -lhdf5'

NETCDF_ROOT='/p/software/default/stages/2025/software/netCDF/4.9.2-npsmpic-2024a'
# long list of netcdf deps, not handled by pkg-config like eccodes
NETCDF_extra_ldflags='-L/p/software/juwels/stages/2025/software/zstd/1.5.6-GCCcore-13.3.0/lib -L/p/software/juwels/stages/2025/software/Szip/2.1.1-GCCcore-13.3.0/lib -L/p/software/juwels/stages/2025/software/PnetCDF/1.13.0-npsmpic-2024a/lib -L/p/software/juwels/stages/2025/software/libxml2/2.12.7-GCCcore-13.3.0/lib -L/p/software/juwels/stages/2025/software/HDF5/1.14.5-npsmpic-2024a/lib -L/p/software/juwels/stages/2025/software/cURL/8.7.1-GCCcore-13.3.0/lib -L/p/software/juwels/stages/2025/software/bzip2/1.0.8-GCCcore-13.3.0/lib -L/p/software/juwels/stages/2025/software/Blosc/1.21.6-GCCcore-13.3.0/lib -L/p/software/juwels/stages/2025/software/CUDA/12/lib'
NETCDF_LIBS='-lnetcdf -lhdf5_hl -lhdf5 -lm -lz -lblosc -lzstd -lbz2 -lsz -lcurl -lpnetcdf -lxml2'

NETCDFF_ROOT='/p/software/default/stages/2025/software/netCDF-Fortran/4.6.1-npsmpic-2024a'
NETCDFF_LIBS='-lnetcdff'

BLAS_LAPACK_LIBS='-llapack -lblas'

ECCODES_ROOT='/p/software/default/stages/2025/software/ecCodes/2.39.0-npsmpic-2024a'
ECCODES_extra_ldflags="$(PKG_CONFIG_PATH=${ECCODES_ROOT}/lib64/pkgconfig:${PKG_CONFIG_PATH-} pkg-config --libs-only-L --libs-only-other --static eccodes)"
ECCODES_LIBS="$(PKG_CONFIG_PATH=${ECCODES_ROOT}/lib64/pkgconfig:${PKG_CONFIG_PATH-} pkg-config --libs-only-l --static eccodes)"

FYAML_ROOT='/p/software/juwels/stages/2025/software/libfyaml/0.9-GCCcore-13.3.0'
FYAML_LIBS='-lfyaml'

XML2_ROOT='/p/software/juwels/stages/2025/software/libxml2/2.12.7-GCCcore-13.3.0'
XML2_LIBS='-lxml2'

extra_ldflags='-L/p/software/juwels/stages/2025/software/OpenSSL/3/lib'

################################################################################

MODULES='Stages/2025 NVHPC/25.3-CUDA-12 ParaStationMPI/5.11.0-1 netCDF-Fortran/4.6.1 ecCodes/2.39.0 libfyaml/.0.9 CMake/3.30.3'
BUILD_ENV="module --force purge; module load ${MODULES}; module list};"

##### Libraries

#HDF5_LIBS='-lhdf5'
#NETCDFF_LIBS='-lnetcdff'
#NETCDF_LIBS='-lnetcdf'
#PNETCDF_LIBS='-lpnetcdf'
#XML2_LIBS='-lxml2'
#FYAML_LIBS='-lfyaml'
#BLAS_LAPACK_LIBS='-llapack -lblas -fortranlibs '
#ECCODES_LIBS='-leccodes'

## Linking to libstc++ is required when using nvfortran + CUDA
#STDCPP_LIBS='-lstdc++'

################################################################################

CC='mpicc'
CFLAGS='-g -O2'
CPPFLAGS="-I${ECCODES_ROOT}/include -I${HDF5_ROOT}/include -I${NETCDF_ROOT}/include -I${XML2_ROOT}/include/libxml2 -I${FYAML_ROOT}/include"

CXX="${NVHPC_ROOT}/Linux_x86_64/25.3/compilers/bin/nvc++"
CXXFLAGS='-g -O2'

FC='mpif90'
FCFLAGS="-I${NETCDFF_ROOT}/include -g -O2 -Mrecursive -Mallocatable=03 -acc=verystrict,gpu -gpu=cc80 -Minfo=accel,inline -Mstack_arrays"
#LDFLAGS="-L${ECCODES_ROOT}/lib64 ${ECCODES_extra_ldflags} -L${HDF5_ROOT}/lib -L${EBROOTPNETCDF}/lib -L${NETCDF_ROOT}/lib64 -L${NETCDFF_ROOT}/lib -L${XML2_ROOT}/lib64 -L${FYAML_ROOT}/lib -L${EBROOTGCCCORE}/lib64"

CUDACXX='nvcc'
CUDAFLAGS='--std=c++14 -arch=sm_80 -g -O3'

LDFLAGS="-L${STDCPP_ROOT}/lib64 -L${CUDA_ROOT}/compat -L${CUDA_ROOT}/lib64 ${extra_ldflags} ${MPI_extra_ldflags} ${NETCDF_extra_ldflags} -L${HDF5_ROOT}/lib -L${NETCDF_ROOT}/lib64 -L${NETCDFF_ROOT}/lib ${ECCODES_extra_ldflags}  -L${ECCODES_ROOT}/lib64 -L${FYAML_ROOT}/lib"

LIBS="${XML2_LIBS} ${BLAS_LAPACK_LIBS} ${NETCDFF_LIBS} ${NETCDF_LIBS} ${HDF5_LIBS} ${ECCODES_LIBS} ${STDCPP_LIBS} -lcudart ${FYAML_LIBS}"

# We use srun to launch MPI. If no active project is available, disable MPI checks.
MPI_LAUNCH="srun"
# --enable-gpu implies --disable-loop-exchange
# --enable-gpu already implies --enable-dim-swap (-D__USE_G2G and -D__SWAPDIM); rte-rrtmgp enabled per default
EXTRA_CONFIG_ARGS='--enable-gpu --enable-mpi-gpu --enable-coupling --enable-grib2 --enable-cdi-pio --disable-parallel-netcdf'

# Speed up the configuration by disabling MPI checks:
EXTRA_CONFIG_ARGS+=' --disable-mpi-checks '

## Workaround for YAC on NVHPC 23.1  -  do we still need this???
#ICON_YAC_CFLAGS='-fortranlibs'
ICON_YAC_CFLAGS=''
ICON_YAC_FCFLAGS=""
#EXTRA_CONFIG_ARGS+=' yac_cv_fc_is_contiguous_works=yes'

################################################################################

"${icon_dir}/configure" \
BUILD_ENV="$BUILD_ENV" \
CC="$CC" \
CFLAGS="$CFLAGS" \
CPPFLAGS="$CPPFLAGS" \
FC="$FC" \
FCFLAGS="$FCFLAGS" \
LDFLAGS="$LDFLAGS" \
ICON_YAC_CFLAGS="$ICON_YAC_CFLAGS" \
ICON_YAC_FCFLAGS="$ICON_YAC_FCFLAGS" \
LIBS="$LIBS" \
MPI_LAUNCH="$MPI_LAUNCH" \
CUDACXX="$CUDACXX" \
CUDAFLAGS="$CUDAFLAGS" \
${EXTRA_CONFIG_ARGS} \
"$@"

for arg in "$@"; do
  case $arg in
    -help | --help | --hel | --he | -h | -help=r* | --help=r* | --hel=r* | --he=r* | -hr* | -help=s* | --help=s* | --hel=s* | --he=s* | -hs*)
      test -n "${EXTRA_CONFIG_ARGS}" && echo '' && echo "This wrapper script ('$0') calls the configure script with the following extra arguments, which might override the default values listed above: ${EXTRA_CONFIG_ARGS}"
      exit 0 ;;
  esac
done

# Copy runscript-related files when building out-of-source:
if test $(pwd) != $(cd "${icon_dir}"; pwd); then
  echo "Copying runscript input files from the source directory..."
  rsync -uavz ${icon_dir}/run . --exclude='*.in' --exclude='.*' --exclude='standard_*' --exclude='*.log'
  ln -sf -t run/ ${icon_dir}/run/standard_*
  rsync -uavz ${icon_dir}/externals . --exclude='.git' --exclude='*.f90' --exclude='*.F90' --exclude='*.c' --exclude='*.h' --exclude='*.Po' --exclude='tests' --exclude='rrtmgp*.nc' --exclude='*.mod' --exclude='*.o'
  rsync -uavz ${icon_dir}/make_runscripts .
  ln -sf ${icon_dir}/data
  ln -sf ${icon_dir}/vertical_coord_tables
fi
