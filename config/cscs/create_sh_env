SCRIPT_DIR=$(cd "$(dirname "$0")"; pwd)
ICON_DIR=$(cd "${SCRIPT_DIR}/../.."; pwd)
VARIANT=$1
BUILD_DIR=$2

# Unset positional parameters
# so they are not forwarded to spack-c2sm/setup-env.sh
set --
set +x

spack env deactivate

spack env activate -p $ICON_DIR/config/cscs/spack/$VARIANT

echo "export ECCODES_DEFINITION_PATH=${ECCODES_DEFINITION_PATH}" >> $BUILD_DIR/setting

if [[ "$(hostname)" == *"balfrin"* || "$(hostname)" == *"tasna"* ]]; then

  echo "export NVCOMPILER_TERM=trace" >> $BUILD_DIR/setting
  echo "export FI_CXI_SAFE_DEVMEM_COPY_THRESHOLD=0" >> $BUILD_DIR/setting

  if [[ "$VARIANT" == *"gpu"* ]]; then

    # add additonal debug exports
    if [[ "$VARIANT" == *"double"* ]]; then
      echo "export NV_TERM=trace" >> $BUILD_DIR/setting
    fi

    # add additonal exports
    echo "export CRAY_CUDA_MPS=1" >> $BUILD_DIR/setting
    echo "export MPICH_GPU_SUPPORT_ENABLED=1" >> $BUILD_DIR/setting
    echo "export MPICH_RDMA_ENABLED_CUDA=1" >> $BUILD_DIR/setting
    echo "export NVCOMPILER_ACC_DEFER_UPLOADS=1" >> $BUILD_DIR/setting
    echo "export NVCOMPILER_ACC_USE_GRAPH=1  # Harmless if cuda-graphs is disabled" >> $BUILD_DIR/setting
    echo "export NVCOMPILER_ACC_NOTIFY=0" >> $BUILD_DIR/setting
    echo "export NVCOMPILER_ACC_SYNCHRONOUS=0" >> $BUILD_DIR/setting
  fi
fi
