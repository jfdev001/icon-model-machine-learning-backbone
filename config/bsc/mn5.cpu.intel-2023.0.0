#!/bin/bash

# ICON
#
# ------------------------------------------
# Copyright (C) 2004-2025, DWD, MPI-M, DKRZ, KIT, ETH, MeteoSwiss
# Contact information: icon-model.org
# See AUTHORS.TXT for a list of authors
# See LICENSES/ for license information
# SPDX-License-Identifier: BSD-3-Clause
# ---------------------------------------

set -xevu
unset CDPATH

script_dir=$(cd "$(dirname "$0")"; pwd)
icon_dir=$(cd "${script_dir}/../.." ; pwd)

MPI_ROOT='/gpfs/apps/MN5/GPP/ONEAPI/2023.0.0/mpi/2021.8.0'

ECCODES_ROOT='/apps/GPP/ECCODES/2.30.2/INTEL/IMPI/'
ECCODES_LIBS='-leccodes'

HDF5_ROOT='/apps/GPP/HDF5/1.14.1-2/INTEL/IMPI/'
HDF5_LIBS='-lhdf5_hl -lhdf5'

NETCDF_ROOT='/apps/GPP/NETCDF/c-4.9.2_fortran-4.6.1_cxx4-4.3.1_hdf5-1.14.1-2_pnetcdf-1.12.3/INTEL/IMPI'
NETCDF_LIBS='-lnetcdf'

NETCDFF_ROOT='/apps/GPP/NETCDF/c-4.9.2_fortran-4.6.1_cxx4-4.3.1_hdf5-1.14.1-2_pnetcdf-1.12.3/INTEL/IMPI'
NETCDFF_LIBS='-lnetcdff'

MKL_ROOT="/gpfs/apps/MN5/GPP/ONEAPI/2023.0.0/mkl/2023.0.0"
BLAS_LAPACK_BUILD_ENV="export LD_LIBRARY_PATH=\"${MKL_ROOT}/lib/intel64:\${LD_LIBRARY_PATH}\";"
BLAS_LAPACK_LDFLAGS='-qmkl=sequential'
BLAS_LAPACK_LIBS=''

FYAML_ROOT="/gpfs/projects/ehpc01/models/icon/libs/libfyaml"
FYAML_LIBS='-lfyaml'

XML2_ROOT='/usr'
XML2_LIBS='-lxml2'

ZLIB_LIBS='-lz'

################################################################################

BUILD_ENV="module load cmake; export LD_LIBRARY_PATH=\"${FYAML_ROOT}/lib:${HDF5_ROOT}/lib:${NETCDF_ROOT}/lib:${NETCDFF_ROOT}/lib:${ECCODES_ROOT}/lib64:\${LD_LIBRARY_PATH}\"; export PATH=\"${MPI_ROOT}/bin:\${PATH}\"; ${BLAS_LAPACK_BUILD_ENV}"

# ARCH Optimizations
ARCH="-m64 -march=core-avx2 -mtune=core-avx2 -fma -ip -pc64"

CC="${MPI_ROOT}/bin/mpicc"
CFLAGS="-diag-disable=10441 -g -gdwarf-4 -qno-opt-dynamic-align ${ARCH}"
CPPFLAGS="-I${HDF5_ROOT}/include -I${NETCDF_ROOT}/include -I${ECCODES_ROOT}/include -I${XML2_ROOT}/include/libxml2 -I${FYAML_ROOT}/include"
ICON_CFLAGS='-O3 -ftz'

FC="${MPI_ROOT}/bin/mpif90"
FCFLAGS="-I${HDF5_ROOT}/include -I${NETCDFF_ROOT}/include -I${ECCODES_ROOT}/include ${ARCH} -g -traceback -gdwarf-4"

ICON_FCFLAGS='-DDO_NOT_COMBINE_PUT_AND_NOCHECK -O3 -ftz -qoverride-limits -assume realloc_lhs -align array64byte -fma -ip -D__SWAPDIM -DOCE_SOLVE_OMP'
ICON_OCEAN_FCFLAGS='-O3 -assume norealloc_lhs -reentrancy threaded -qopt-report-file=stdout -qopt-report=0 -qopt-report-phase=vec'

# Common Fotran and C Compiler flags
LDFLAGS="-L${HDF5_ROOT}/lib -L${NETCDF_ROOT}/lib -L${NETCDFF_ROOT}/lib ${BLAS_LAPACK_LDFLAGS} -L${ECCODES_ROOT}/lib64 -L${FYAML_ROOT}/lib"
LIBS="-Wl,--disable-new-dtags -Wl,--as-needed ${XML2_LIBS} ${FYAML_LIBS} ${ECCODES_LIBS} ${BLAS_LAPACK_LIBS} ${NETCDFF_LIBS} ${NETCDF_LIBS} ${HDF5_LIBS} ${ZLIB_LIBS}"

# XIAR (Essentially uses AR) - Used in the .config script for archive management
AR="xiar"

MPI_LAUNCH="srun"

EXTRA_CONFIG_ARGS='--enable-intel-consistency --enable-vectorized-lrtm --enable-grib2 --enable-fcgroup-OCEAN=src/hamocc:src/ocean:src/sea_ice --disable-mpi-checks --enable-openmp'

ICON_BUNDLED_CFLAGS="-O2 -ftz"
ICON_YAC_CFLAGS=$ICON_BUNDLED_CFLAGS
ICON_CDI_CFLAGS=$ICON_BUNDLED_CFLAGS
ICON_ECRAD_FCFLAGS="-qno-opt-dynamic-align -no-fma -fpe"

################################################################################

"${icon_dir}/configure" \
AR="${AR}" \
BUILD_ENV="${BUILD_ENV}" \
CC="${CC}" \
CFLAGS="${CFLAGS}" \
CPPFLAGS="${CPPFLAGS}" \
FC="${FC}" \
FCFLAGS="${FCFLAGS}" \
ICON_BUNDLED_CFLAGS="${ICON_BUNDLED_CFLAGS}" \
ICON_CDI_CFLAGS="${ICON_CDI_CFLAGS}" \
ICON_CFLAGS="${ICON_CFLAGS}" \
ICON_ECRAD_FCFLAGS="${ICON_ECRAD_FCFLAGS}" \
ICON_FCFLAGS="${ICON_FCFLAGS}" \
ICON_OCEAN_FCFLAGS="${ICON_OCEAN_FCFLAGS}" \
ICON_YAC_CFLAGS="${ICON_YAC_CFLAGS}" \
LDFLAGS="${LDFLAGS}" \
LIBS="${LIBS}" \
MPI_LAUNCH="${MPI_LAUNCH}" \
${EXTRA_CONFIG_ARGS} \
"$@"

for arg in "$@"; do
  case $arg in
    -help | --help | --hel | --he | -h | -help=r* | --help=r* | --hel=r* | --he=r* | -hr* | -help=s* | --help=s* | --hel=s* | --he=s* | -hs*)
      test -n "${EXTRA_CONFIG_ARGS}" && echo '' && echo "This wrapper script ('$0') calls the configure script with the following extra arguments, which might override the default values listed above: ${EXTRA_CONFIG_ARGS}"
      exit 0 ;;
  esac
done

# Copy runscript-related files when building out-of-source:
if test $(pwd) != $(cd "${icon_dir}"; pwd); then
  echo "Copying runscript input files from the source directory..."
  rsync -uavz ${icon_dir}/run . --exclude='*.in' --exclude='.*' --exclude='standard_*' --exclude=mkexp
  ln -sf -t run/ ${icon_dir}/run/{standard_*,mkexp}
  rsync -uavz ${icon_dir}/externals . --exclude='.git' --exclude='*.f90' --exclude='*.F90' --exclude='*.c' --exclude='*.h' --exclude='*.Po' --exclude='tests' --exclude='*.mod' --exclude='*.o'
  rsync -uavz ${icon_dir}/make_runscripts .
  rsync -uavz ${icon_dir}/scripts .
  ln -sf ${icon_dir}/data
  ln -sf ${icon_dir}/vertical_coord_tables
fi
