set specs       [split [module-info name] /]
set name        [lindex $specs 0]
set version     [lindex $specs 1]

conflict $name

proc ModulesHelp { } {
    global name version
    puts stderr "\t$name - loads version $version of the $name package"
}

module-whatis "loads the $name package"
