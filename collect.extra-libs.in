build_prefix='@abs_top_builddir@/'

strip_build_prefix="^`echo "$build_prefix" | sed 's|.|.|g'`"
strip_build_prefix_fn ()
{
  # Updates a shell variable by removing the absolute path to the root build
  # directory of ICON from the beginning of its value. Does nothing if the value
  # does not start with the path to the build directory.
  #   Arguments:
  #     $1 - name of the shell variable to modify.

  eval sbp_value=\$$1
  case $sbp_value in
    "$build_prefix"*)
      eval "$1=\`echo \$sbp_value | sed 's,$strip_build_prefix,,'\`" ;;
  esac
}

query_config_status_fn ()
{
  # Sets a shell variable to the result of the variable substitution in a
  # template by the config.status. Provides a way of getting results of an
  # Autoconf configure script.
  #   Arguments:
  #     $1 - name of the shell variable to store the result;
  #     $2 - relative path (with respect to the root build directory of ICON) to
  #          the root build directory of an Autoconf-based package;
  #     $3 - substitution template.

  eval "$1=\`echo \$3 | '$2/config.status' -q --file=-\`"
}

query_libtool_CC_fn ()
{
  # Sets a shell variable to the value of the specified parameter generated by
  # the libtool script. Provides a way of getting the internal compiler and
  # linker flags detected by a Libtool-based build system.
  #   Arguments:
  #     $1 - name of the shell variable to store the result;
  #     $2 - relative path (with respect to the root build directory of ICON) to
  #          the root build directory of a Libtool-based package;
  #     $3 - name of the requested Libtool parameter (e.g. dependency_libs).

  @MKDIR_P@ conftest.dir
  (
    cd conftest.dir
    query_config_status_fn ql_LINK "../$2" \
      '@''SHELL@ ../'"$2"'/libtool --tag=CC --mode=link @''CC@ @''CFLAGS@ @''LDFLAGS@ -o libconftest.la @''LIBS@'
    (eval $ql_LINK) >/dev/null 2>&1
  )
  ql_ec=$?
  test $ql_ec -ne 0 || {
    eval "$1=\`. conftest.dir/libconftest.la >/dev/null 2>&1 && echo \$$3\`"
  }
  rm -rf conftest.dir
  return $ql_ec
}

query_cmake_cache_fn ()
{
  # Sets a shell variable to the value of a CMake cache variable.
  #   Arguments:
  #     $1 - name of the shell variable to store the result;
  #     $2 - relative path (with respect to the root build directory of ICON) to
  #          the root build directory of a CMake-based package;
  #     $3 - name of the CMake cache variable.

  eval "$1=\`@CMAKE@ -L -N '$2' | sed -n 's,^$3\\(:[A-Z]\\+\\)\\?=\\(.*\\),\\2,p'\`"
}

query_cmake_wrapper_fn ()
{
  # Sets a shell variable to the list of linker arguments generated by the ICON
  # CMake wrapper.
  #   Arguments:
  #     $1 - name of the shell variable to store the result;
  #     $2 - relative path (with respect to the root build directory of ICON) to
  #          the root build directory of a CMake-based package that was
  #          configured via the ICON CMake wrapper.

  qcw_output=$1
  qcw_subdir=$2
  set dummy `cat "$qcw_subdir/CMakeFiles/icon-extra-libs.dir/link.txt" 2>/dev/null`; shift
  for qcw_arg; do
    case $qcw_arg in
      # Copy flags as-is:
      -*) ;;
      # Strip the build directory prefix in the absolute paths:
      /*) strip_build_prefix_fn qcw_arg ;;
      # The argument might be a path relative to the build directory of the
      # package. If that is the case, prepend the argument with the path to the
      # build directory:
      *) test -d "$qcw_subdir/`echo $qcw_arg | sed 's,[^/]*$,,'`" && \
           qcw_arg="$qcw_subdir/$qcw_arg" ;;
    esac
    strip_build_prefix_fn qcw_arg
    case ' @BUNDLED_LIBFILES@ @ICON_CMAKE_EXCLUDE@ ' in
      *" $qcw_arg "*) continue ;;
    esac
    eval "$qcw_output=\"\$$qcw_output $qcw_arg\""
  done
}

# Collect extra dependencies of the bundled libraries:

output=''

test $# -ne 0 || {
  set dummy @icon_bundled_builddirs@; shift
}

for subdir; do

  test -f "$subdir/Makefile" || {
    echo "$0: WARNING: directory '$subdir' is not configured" >&2
    continue
  }

  extra_libs=''

  case $subdir in
    externals/comin/build)
      # The bundled version of COMIN might require linking to libdl:
      query_cmake_cache_fn comin_DL_LIBS "$subdir" COMIN_DL_LIBS
      for arg in $comin_DL_LIBS; do
        case $arg in
          -l*) ;;
          *) arg="-l$arg" ;;
        esac
        extra_libs="$extra_libs${extra_libs:+ }$arg"
      done
      ;;
    externals/sct)
      # The bundled version of SCT might require:
      #   1) linking to librt;
      query_config_status_fn sct_LIBS "$subdir" '@''LIBS@'
      case " $sct_LIBS " in
        *' -lrt '*) extra_libs='-lrt' ;;
      esac
      #   2) linking to C code that uses OpenMP.
      query_config_status_fn sct_OPENMP_FC_C_FLAGS "$subdir" '@''OPENMP_FC_C_FLAGS@'
      extra_libs="$sct_OPENMP_FC_C_FLAGS${extra_libs:+ }$extra_libs"
      ;;
    externals/cdi)
      # The bundled version of CDI might require linking to librt:
      query_config_status_fn extra_libs "$subdir" '@''LIBRT@'
      test -n "$extra_libs" || {
        query_config_status_fn cdi_ENABLE_MPI_TRUE "$subdir" '@''ENABLE_MPI_TRUE@'
        test -n "$cdi_ENABLE_MPI_TRUE" || {
          # We are here because either CDI does not depend on librt or the
          # dependency is hidden by the libtool script of CDI (e.g. it found a
          # libtool .la file that has '-lrt' among the 'dependency_libs',
          # overlinked to librt and the configure script of CDI reported that no
          # additional linker flags are required to link to the library, hence
          # LIBRT was set to an empty string). The absence of the dependency on
          # librt is very unlikely and here we could simply set the variable
          # extra_libs to '-lrt'. However, we use this case as an example of how
          # such issues can be resolved in general. Note that libcdipio.la might
          # not exist yet, therefore we cannot parse it. Instead, we run the
          # libtool script of CDI and retreive the dependency_libs variable:
          query_libtool_CC_fn cdi_dependency_libs "$subdir" dependency_libs && {
            case " $cdi_dependency_libs " in
              *' -lrt '*) extra_libs='-lrt' ;;
            esac
          }
        }
      }
      ;;
  esac

  output="$extra_libs${output:+${extra_libs:+ }}$output"

done

echo "$output"
